            <!-- M4.9.4: Typography scale (non-theme, global). -->
            <x:Double x:Key="TextFontSizeDisplay">18</x:Double>
            <x:Double x:Key="TextFontSizeTitle">16</x:Double>
            <x:Double x:Key="TextFontSizeBody">13</x:Double>
            <x:Double x:Key="TextFontSizeBodyCjk">14</x:Double>
            <x:Double x:Key="TextFontSizeCaption">12</x:Double>
            <x:Double x:Key="TextFontSizeLabel">11</x:Double>
            <x:Double x:Key="TextFontSizeBadge">10</x:Double>

            <!-- M4.11: Nocturne motion is deliberately short and quiet. Native
                 theme transitions respect the user's Reduce Motion preference. -->
            <x:Double x:Key="MotionQuickMs">120</x:Double>
            <x:Double x:Key="MotionStandardMs">180</x:Double>
            <x:Double x:Key="MotionPanelMs">220</x:Double>

            <!-- M4.9.4: Spacing scale (non-theme, global). -->
            <x:Double x:Key="SpaceXS">4</x:Double>
            <x:Double x:Key="SpaceS">8</x:Double>
            <x:Double x:Key="SpaceM">12</x:Double>
            <x:Double x:Key="SpaceL">16</x:Double>
            <x:Double x:Key="SpaceXL">20</x:Double>
            <x:Double x:Key="SpaceXXL">26</x:Double>

            <!-- M4.9.4: Corner radius scale (non-theme, global). -->
            <CornerRadius x:Key="RadiusContainer">8</CornerRadius>
            <CornerRadius x:Key="RadiusCard">7</CornerRadius>
            <CornerRadius x:Key="RadiusBadge">6</CornerRadius>
            <CornerRadius x:Key="RadiusTag">5</CornerRadius>
            <CornerRadius x:Key="RadiusBar">2</CornerRadius>

            <!-- M4.9.4: Primary font family — CJK-aware (YaHei UI for Chinese,
                 Segoe UI Variable for Latin), with Consolas for monospace. -->
            <FontFamily x:Key="TextPrimaryFontFamily">Microsoft YaHei UI, Segoe UI Variable, Segoe UI</FontFamily>
            <FontFamily x:Key="MonoFontFamily">Consolas, Cascadia Mono, Courier New</FontFamily>

            <!-- M4.11: one optical icon language for the primary workbench. -->
            <Style x:Key="NocturneIconStyle" TargetType="FontIcon">
                <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="Foreground" Value="{ThemeResource TextSecondaryBrush}" />
            </Style>
            <Style x:Key="NocturneIconButtonStyle" TargetType="Button">
                <Setter Property="Width" Value="38" />
                <Setter Property="Height" Value="38" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Background" Value="{ThemeResource SurfaceElevatedBrush}" />
                <Setter Property="Foreground" Value="{ThemeResource TextSecondaryBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource BorderSubtleBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="{StaticResource RadiusContainer}" />
            </Style>
            <Style x:Key="NocturneContextChipStyle" TargetType="Button">
                <Setter Property="MinHeight" Value="34" />
                <Setter Property="Padding" Value="10,6" />
                <Setter Property="Background" Value="{ThemeResource InputBackgroundBrush}" />
                <Setter Property="Foreground" Value="{ThemeResource TextSecondaryBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource BorderSubtleBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="{StaticResource RadiusBadge}" />
            </Style>

            <!-- M4.9.5 Phase F3: apply the CJK-aware primary font globally via
                 an implicit TextBlock style (no BasedOn — WinUI 3's default
                 TextBlock style key isn't reliably resolvable here, and a
                 bare style that only sets FontFamily still inherits the
                 platform defaults for everything else). -->
            <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource TextPrimaryFontFamily}" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
