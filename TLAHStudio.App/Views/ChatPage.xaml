<UserControl
    x:Class="TLAHStudio.App.Views.ChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border
            x:Name="AgentStatusBar"
            Grid.Row="0"
            Margin="24,14,24,0"
            Padding="12,9"
            Visibility="Collapsed"
            Background="{ThemeResource PanelAltBrush}"
            BorderBrush="{ThemeResource BorderSubtleBrush}"
            BorderThickness="1"
            CornerRadius="8"
            AutomationProperties.Name="Agent run status">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ProgressRing
                    x:Name="AgentProgressRing"
                    Width="18"
                    Height="18"
                    IsActive="False"
                    VerticalAlignment="Center" />
                <TextBlock
                    x:Name="AgentStatusText"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    TextWrapping="Wrap"
                    Foreground="{ThemeResource TextSecondaryBrush}" />
                <Button
                    x:Name="ResumeAgentButton"
                    Grid.Column="2"
                    Click="ResumeAgent_Click"
                    Visibility="Collapsed"
                    Padding="10,5"
                    CornerRadius="8"
                    Background="{ThemeResource SurfaceElevatedBrush}"
                    Foreground="{ThemeResource TextPrimaryBrush}"
                    BorderBrush="{ThemeResource BorderSubtleBrush}"
                    AutomationProperties.Name="Resume agent run">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <SymbolIcon Symbol="Play" />
                        <TextBlock Text="Resume" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
        <ScrollViewer
            x:Name="MessagesScrollViewer"
            Grid.Row="1"
            Padding="24,18"
            VerticalScrollBarVisibility="Auto"
            VerticalScrollMode="Enabled"
            HorizontalScrollBarVisibility="Disabled"
            HorizontalScrollMode="Disabled"
            ZoomMode="Disabled"
            AutomationProperties.Name="Conversation messages">
            <StackPanel
                x:Name="MessagesStack"
                Spacing="14" />
        </ScrollViewer>
    </Grid>
</UserControl>
