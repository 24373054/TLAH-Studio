<UserControl
    x:Class="TLAHStudio.App.Views.ChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border
            x:Name="AgentStatusBar"
            Grid.Row="0"
            Margin="26,16,26,0"
            Padding="16,11"
            Visibility="Collapsed"
            Background="{ThemeResource SurfaceBrush}"
            BorderBrush="{ThemeResource BorderSubtleBrush}"
            BorderThickness="1"
            CornerRadius="8"
            AutomationProperties.Name="Agent run status">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid Width="18" Height="18" VerticalAlignment="Center">
                    <Border
                        x:Name="AgentStatusSignal"
                        Width="8"
                        Height="8"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{ThemeResource AccentSecondaryBrush}"
                        CornerRadius="4" />
                    <ProgressRing
                        x:Name="AgentProgressRing"
                        Width="18"
                        Height="18"
                        IsActive="False"
                        Visibility="Collapsed" />
                </Grid>
                <TextBlock
                    x:Name="AgentStatusText"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    TextWrapping="Wrap"
                    Foreground="{ThemeResource TextSecondaryBrush}" />
                <Button
                    x:Name="ResumeAgentButton"
                    Grid.Column="2"
                    Click="ResumeAgent_Click"
                    Visibility="Collapsed"
                    Padding="10,5"
                    CornerRadius="8"
                    Background="{ThemeResource SurfaceElevatedBrush}"
                    Foreground="{ThemeResource TextPrimaryBrush}"
                    BorderBrush="{ThemeResource BorderSubtleBrush}"
                    AutomationProperties.Name="Resume agent run">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <SymbolIcon Symbol="Play" />
                        <TextBlock Text="Resume" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
        <Grid Grid.Row="1">
            <ScrollViewer
                x:Name="MessagesScrollViewer"
                Padding="26,20"
                VerticalScrollBarVisibility="Auto"
                VerticalScrollMode="Enabled"
                HorizontalScrollBarVisibility="Disabled"
                HorizontalScrollMode="Disabled"
                IsScrollInertiaEnabled="True"
                ZoomMode="Disabled"
                ViewChanged="MessagesScrollViewer_ViewChanged"
                PointerWheelChanged="MessagesScrollViewer_PointerWheelChanged"
                AutomationProperties.Name="Conversation messages">
                <!-- A repeater only realizes the visible portion of the timeline.
                     Its element factory keeps rich message rendering in C# while
                     avoiding a retained visual for every historic message. -->
                <ItemsRepeater x:Name="MessagesRepeater">
                    <ItemsRepeater.Layout>
                        <StackLayout x:Name="TimelineLayout" Spacing="16" />
                    </ItemsRepeater.Layout>
                </ItemsRepeater>
            </ScrollViewer>

            <ContentControl
                x:Name="ConversationStateHost"
                Margin="26,20"
                HorizontalContentAlignment="Stretch"
                VerticalContentAlignment="Stretch"
                IsHitTestVisible="False"
                Visibility="Collapsed" />
        </Grid>
    </Grid>
</UserControl>
