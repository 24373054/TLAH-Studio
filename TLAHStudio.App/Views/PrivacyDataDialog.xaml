<ContentDialog
    x:Class="TLAHStudio.App.Views.PrivacyDataDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Privacy &amp; Data"
    CloseButtonText="Close"
    Background="{ThemeResource DialogSurfaceBrush}"
    Width="720"
    AutomationProperties.Name="Privacy and data management">

    <Grid RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Padding="14,12"
            Background="{ThemeResource AccentSoftBrush}"
            BorderBrush="{ThemeResource BorderSubtleBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <SymbolIcon Symbol="Document" Foreground="{ThemeResource AccentBrush}" VerticalAlignment="Top" />
                <StackPanel Grid.Column="1" Spacing="5">
                    <TextBlock
                        x:Name="SummaryText"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextPrimaryBrush}"
                        TextWrapping="Wrap" />
                    <TextBlock
                        Text="Exports exclude API keys. Diagnostic data is redacted before it is written to disk."
                        Foreground="{ThemeResource TextSecondaryBrush}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="10">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Click="ExportData_Click" HorizontalAlignment="Stretch" Padding="12,9" CornerRadius="8" AutomationProperties.Name="Export all local data">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <SymbolIcon Symbol="Save" />
                            <TextBlock Text="Export Data" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="1" Click="ImportData_Click" HorizontalAlignment="Stretch" Padding="12,9" CornerRadius="8" AutomationProperties.Name="Import local data">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <SymbolIcon Symbol="OpenFile" />
                            <TextBlock Text="Import Data" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="2" Click="ExportDiagnostics_Click" HorizontalAlignment="Stretch" Padding="12,9" CornerRadius="8" AutomationProperties.Name="Export diagnostics bundle">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <SymbolIcon Symbol="Document" />
                            <TextBlock Text="Diagnostics" />
                        </StackPanel>
                    </Button>
                </Grid>

                <Border
                    Padding="12"
                    Background="{ThemeResource InputBackgroundBrush}"
                    BorderBrush="{ThemeResource BorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Diagnostics Preview" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}" />
                        <TextBox
                            x:Name="PreviewBox"
                            IsReadOnly="True"
                            AcceptsReturn="True"
                            TextWrapping="Wrap"
                            MinHeight="260"
                            MaxHeight="360"
                            FontFamily="Consolas"
                            FontSize="12"
                            Background="{ThemeResource InputBackgroundBrush}"
                            Foreground="{ThemeResource TextPrimaryBrush}"
                            BorderBrush="{ThemeResource BorderSubtleBrush}"
                            AutomationProperties.Name="Redacted diagnostics preview" />
                    </StackPanel>
                </Border>

                <Border
                    Padding="12"
                    Background="{ThemeResource SurfaceBrush}"
                    BorderBrush="{ThemeResource BorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Text="Clear all local chats, debug records, provider settings, API keys, and local preferences from this Windows account."
                            Foreground="{ThemeResource TextSecondaryBrush}"
                            TextWrapping="Wrap" />
                        <Button
                            x:Name="ClearDataButton"
                            Grid.Column="1"
                            Background="{ThemeResource DangerBrush}"
                            Foreground="{ThemeResource AccentTextBrush}"
                            BorderThickness="0"
                            CornerRadius="8"
                            Padding="14,9"
                            Content="Clear All"
                            AutomationProperties.Name="Clear all local data">
                            <Button.Flyout>
                                <Flyout x:Name="ClearDataFlyout" Placement="TopEdgeAlignedRight">
                                    <StackPanel Width="320" Spacing="12">
                                        <TextBlock
                                            Text="Clear all local data?"
                                            FontSize="18"
                                            FontWeight="SemiBold"
                                            Foreground="{ThemeResource TextPrimaryBrush}" />
                                        <TextBlock
                                            Text="This removes chats, debug history, API keys, and local preferences from this Windows account. This action cannot be undone."
                                            Foreground="{ThemeResource TextSecondaryBrush}"
                                            TextWrapping="Wrap" />
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Button
                                                HorizontalAlignment="Stretch"
                                                Click="CancelClearData_Click"
                                                Content="Cancel"
                                                AutomationProperties.Name="Cancel clearing local data" />
                                            <Button
                                                Grid.Column="1"
                                                HorizontalAlignment="Stretch"
                                                Click="ConfirmClearData_Click"
                                                Background="{ThemeResource DangerBrush}"
                                                Foreground="{ThemeResource AccentTextBrush}"
                                                BorderThickness="0"
                                                Content="Clear All"
                                                AutomationProperties.Name="Confirm clearing all local data" />
                                        </Grid>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <TextBlock
            x:Name="StatusText"
            Grid.Row="2"
            Foreground="{ThemeResource TextSecondaryBrush}"
            TextWrapping="Wrap" />
    </Grid>
</ContentDialog>
