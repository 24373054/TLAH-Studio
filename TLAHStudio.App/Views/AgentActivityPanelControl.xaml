<UserControl
    x:Class="TLAHStudio.App.Views.AgentActivityPanelControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid
        x:Name="PanelRoot"
        Background="{ThemeResource AppChromeBrush}"
        BorderBrush="{ThemeResource BorderSubtleBrush}"
        BorderThickness="1,0,0,0"
        MinWidth="300"
        AutomationProperties.Name="Agent activity panel">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid
            Grid.Row="0"
            Padding="18,18,14,14"
            ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="3">
                <TextBlock Text="AGENT TRACE" FontSize="10" FontWeight="SemiBold" CharacterSpacing="65" Foreground="{ThemeResource TextMutedBrush}" />
                <TextBlock
                    Text="Agent Activity"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource TextPrimaryBrush}" />
                <TextBlock
                    x:Name="SummaryText"
                    Text="No agent activity yet."
                    FontSize="12"
                    TextWrapping="Wrap"
                    Foreground="{ThemeResource TextSecondaryBrush}" />
            </StackPanel>
            <Button
                Grid.Column="1"
                Click="Collapse_Click"
                Style="{StaticResource NocturneIconButtonStyle}"
                ToolTipService.ToolTip="Collapse activity panel"
                AutomationProperties.Name="Collapse activity panel">
                <FontIcon Glyph="&#xE72C;" Style="{StaticResource NocturneIconStyle}" />
            </Button>
        </Grid>

        <Border
            Grid.Row="1"
            Height="1"
            Background="{ThemeResource BorderSubtleBrush}" />

        <Grid Grid.Row="2">
            <ScrollViewer
                x:Name="ActivityScrollViewer"
                Padding="16,16,16,18"
                VerticalScrollBarVisibility="Auto"
                VerticalScrollMode="Enabled"
                HorizontalScrollBarVisibility="Disabled"
                HorizontalScrollMode="Disabled"
                IsScrollInertiaEnabled="True"
                ZoomMode="Disabled">
                <ItemsRepeater x:Name="ActivityRepeater">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="12" />
                    </ItemsRepeater.Layout>
                </ItemsRepeater>
            </ScrollViewer>
            <ContentControl
                x:Name="ActivityEmptyStateHost"
                Margin="14,14,14,16"
                VerticalAlignment="Top" />
        </Grid>
    </Grid>
</UserControl>
