<UserControl
    x:Class="TLAHStudio.App.Views.AgentActivityPanelControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid
        x:Name="PanelRoot"
        Background="{ThemeResource AppChromeBrush}"
        BorderBrush="{ThemeResource BorderSubtleBrush}"
        BorderThickness="1,0,0,0"
        MinWidth="300"
        AutomationProperties.Name="Agent activity panel">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid
            Grid.Row="0"
            Padding="16,15,14,12"
            ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="2">
                <TextBlock
                    Text="Agent Activity"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource TextPrimaryBrush}" />
                <TextBlock
                    x:Name="SummaryText"
                    Text="No agent activity yet."
                    FontSize="12"
                    TextWrapping="Wrap"
                    Foreground="{ThemeResource TextSecondaryBrush}" />
            </StackPanel>
            <Button
                Grid.Column="1"
                Click="Collapse_Click"
                Width="34"
                Height="34"
                Padding="0"
                CornerRadius="8"
                Background="{ThemeResource SurfaceElevatedBrush}"
                Foreground="{ThemeResource TextSecondaryBrush}"
                BorderBrush="{ThemeResource BorderSubtleBrush}"
                ToolTipService.ToolTip="Collapse activity panel"
                AutomationProperties.Name="Collapse activity panel">
                <SymbolIcon Symbol="Forward" />
            </Button>
        </Grid>

        <Border
            Grid.Row="1"
            Height="1"
            Background="{ThemeResource BorderSubtleBrush}" />

        <ScrollViewer
            x:Name="ActivityScrollViewer"
            Grid.Row="2"
            Padding="14,14,14,16"
            VerticalScrollBarVisibility="Auto"
            VerticalScrollMode="Enabled"
            HorizontalScrollBarVisibility="Disabled"
            HorizontalScrollMode="Disabled"
            ZoomMode="Disabled">
            <StackPanel
                x:Name="ActivityStack"
                Spacing="12" />
        </ScrollViewer>
    </Grid>
</UserControl>
