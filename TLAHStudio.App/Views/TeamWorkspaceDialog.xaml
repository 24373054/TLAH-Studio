<ContentDialog
    x:Class="TLAHStudio.App.Views.TeamWorkspaceDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Workspace"
    PrimaryButtonText="Save project"
    PrimaryButtonClick="PrimaryButton_Click"
    CloseButtonText="Close"
    DefaultButton="Primary"
    Background="{ThemeResource DialogSurfaceBrush}">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMaxWidth">1280</x:Double>
        <x:Double x:Key="ContentDialogMaxHeight">1000</x:Double>
    </ContentDialog.Resources>

    <Grid
        x:Name="WorkspaceRoot"
        Width="1120"
        MaxWidth="1120"
        RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer
            HorizontalScrollBarVisibility="Hidden"
            HorizontalScrollMode="Enabled"
            VerticalScrollBarVisibility="Disabled"
            VerticalScrollMode="Disabled">
        <Border
            HorizontalAlignment="Left"
            Padding="3"
            Background="{ThemeResource PanelAltBrush}"
            BorderBrush="{ThemeResource BorderSubtleBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <StackPanel Orientation="Horizontal" Spacing="3">
                <Button x:Name="ProjectTabButton" Content="Overview" Tag="project" Click="Tab_Click" Background="Transparent" BorderThickness="0" Padding="14,7" CornerRadius="6" AutomationProperties.Name="Show project overview" />
                <Button x:Name="ProfilesTabButton" Content="Profiles" Tag="profiles" Click="Tab_Click" Background="Transparent" BorderThickness="0" Padding="14,7" CornerRadius="6" AutomationProperties.Name="Show config profiles" />
                <Button x:Name="TemplatesTabButton" Content="Templates" Tag="templates" Click="Tab_Click" Background="Transparent" BorderThickness="0" Padding="14,7" CornerRadius="6" AutomationProperties.Name="Show prompt templates" />
                <Button x:Name="AuditTabButton" Content="Activity" Tag="audit" Click="Tab_Click" Background="Transparent" BorderThickness="0" Padding="14,7" CornerRadius="6" AutomationProperties.Name="Show audit log" />
                <Button x:Name="SyncTabButton" Content="Transfer" Tag="sync" Click="Tab_Click" Background="Transparent" BorderThickness="0" Padding="14,7" CornerRadius="6" AutomationProperties.Name="Show workspace transfer" />
            </StackPanel>
        </Border>
        </ScrollViewer>

        <Grid x:Name="WorkspaceBodyGrid" Grid.Row="1" ColumnSpacing="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="WorkspaceRailColumn" Width="228" />
                <ColumnDefinition x:Name="WorkspaceDetailColumn" Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Background="{ThemeResource PanelAltBrush}"
                x:Name="ProjectRail"
                BorderBrush="{ThemeResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Spacing="8">
                        <TextBlock Text="Project workspace" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}" />
                        <TextBlock Text="Choose the active project space." FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" TextWrapping="Wrap" />
                        <ComboBox
                            x:Name="ProjectCombo"
                            DisplayMemberPath="Name"
                            SelectionChanged="ProjectCombo_SelectionChanged"
                            MinHeight="38"
                            Background="{ThemeResource InputBackgroundBrush}"
                            Foreground="{ThemeResource TextPrimaryBrush}"
                            BorderBrush="{ThemeResource BorderSubtleBrush}"
                            CornerRadius="8"
                            HorizontalAlignment="Stretch"
                            AutomationProperties.Name="Project spaces" />
                        <Button Click="NewProject_Click" MinHeight="38" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="10,7" CornerRadius="8" AutomationProperties.Name="New project">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <SymbolIcon Symbol="Add" />
                                <TextBlock Text="New Project" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Row="1" VerticalAlignment="Bottom" Spacing="8">
                        <TextBlock
                            x:Name="ProjectStatsText"
                            TextWrapping="Wrap"
                            FontSize="12"
                            Foreground="{ThemeResource TextSecondaryBrush}" />
                        <TextBlock
                            x:Name="StatusText"
                            TextWrapping="Wrap"
                            FontSize="12"
                            Foreground="{ThemeResource TextSecondaryBrush}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid x:Name="WorkspaceDetail" Grid.Column="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <StackPanel x:Name="ProjectPanel" Spacing="10">
                            <TextBlock Text="Project Details" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}" />
                            <TextBlock Text="Name" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                            <TextBox x:Name="ProjectNameBox" Background="{ThemeResource InputBackgroundBrush}" Foreground="{ThemeResource TextPrimaryBrush}" BorderBrush="{ThemeResource BorderSubtleBrush}" CornerRadius="8" AutomationProperties.Name="Project name" />
                            <TextBlock Text="Description" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                            <TextBox x:Name="ProjectDescriptionBox" MinHeight="54" AcceptsReturn="True" TextWrapping="Wrap" Background="{ThemeResource InputBackgroundBrush}" Foreground="{ThemeResource TextPrimaryBrush}" BorderBrush="{ThemeResource BorderSubtleBrush}" CornerRadius="8" AutomationProperties.Name="Project description" />
                            <TextBlock Text="Shared Prompt" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                            <TextBox x:Name="SharedPromptBox" MinHeight="108" AcceptsReturn="True" TextWrapping="Wrap" Background="{ThemeResource InputBackgroundBrush}" Foreground="{ThemeResource TextPrimaryBrush}" BorderBrush="{ThemeResource BorderSubtleBrush}" CornerRadius="8" AutomationProperties.Name="Shared prompt" />
                            <TextBlock Text="Team Norms" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                            <TextBox x:Name="TeamNormsBox" MinHeight="108" AcceptsReturn="True" TextWrapping="Wrap" Background="{ThemeResource InputBackgroundBrush}" Foreground="{ThemeResource TextPrimaryBrush}" BorderBrush="{ThemeResource BorderSubtleBrush}" CornerRadius="8" AutomationProperties.Name="Team norms" />
                            <TextBlock Text="Default Profile" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                            <ComboBox x:Name="DefaultProfileCombo" DisplayMemberPath="Name" Background="{ThemeResource InputBackgroundBrush}" Foreground="{ThemeResource TextPrimaryBrush}" BorderBrush="{ThemeResource BorderSubtleBrush}" CornerRadius="8" AutomationProperties.Name="Default config profile" />
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                <Button Click="AssignChat_Click" Padding="12,7" CornerRadius="8" AutomationProperties.Name="Assign current chat to workspace">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <SymbolIcon Symbol="Link" />
                                        <TextBlock Text="Assign Chat" />
                                    </StackPanel>
                                </Button>
                                <Button Click="SaveProject_Click" Background="{ThemeResource AccentBrush}" Foreground="{ThemeResource AccentTextBrush}" BorderThickness="0" Padding="16,7" CornerRadius="8" AutomationProperties.Name="Save project">Save Project</Button>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel x:Name="ProfilesPanel" Visibility="Collapsed" Spacing="10">
                            <Grid x:Name="ProfilesLayoutGrid" ColumnSpacing="12" RowSpacing="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition x:Name="ProfilesListColumn" Width="230" />
                                    <ColumnDefinition x:Name="ProfileEditorColumn" Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel x:Name="ProfilesListSection" Spacing="8">
                                    <TextBlock Text="Config Profiles" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}" />
                                    <ListView x:Name="ProfileList" Height="430" DisplayMemberPath="Name" SelectionChanged="ProfileList_SelectionChanged" Background="{ThemeResource SurfaceBrush}" BorderBrush="{ThemeResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="8" AutomationProperties.Name="Config profiles" />
                                    <Button Click="NewProfile_Click" Padding="10,7" CornerRadius="8" AutomationProperties.Name="New profile">New Profile</Button>
                                </StackPanel>
                                <StackPanel x:Name="ProfileEditorSection" Grid.Column="1" Spacing="8">
                                    <TextBlock Text="Name" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                                    <TextBox x:Name="ProfileNameBox" Background="{ThemeResource InputBackgroundBrush}" Foreground="{ThemeResource TextPrimaryBrush}" BorderBrush="{ThemeResource BorderSubtleBrush}" CornerRadius="8" />
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="Provider" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                                            <TextBox x:Name="ProfileProviderBox" Background="{ThemeResource InputBackgroundBrush}" Foreground="{ThemeResource TextPrimaryBrush}" BorderBrush="{ThemeResource BorderSubtleBrush}" CornerRadius="8" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="6">
                                            <TextBlock Text="Model" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                                            <TextBox x:Name="ProfileModelBox" Background="{ThemeResource InputBackgroundBrush}" Foreground="{ThemeResource TextPrimaryBrush}" BorderBrush="{ThemeResource BorderSubtleBrush}" CornerRadius="8" />
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock Text="API Key Override" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                                    <PasswordBox x:Name="ProfileApiKeyBox" PlaceholderText="Leave blank to inherit global key" PasswordRevealMode="Peek" Background="{ThemeResource InputBackgroundBrush}" Foreground="{ThemeResource TextPrimaryBrush}" BorderBrush="{ThemeResource BorderSubtleBrush}" CornerRadius="8" AutomationProperties.Name="Profile API key override" />
                                    <TextBlock Text="Base URL" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                                    <TextBox x:Name="ProfileBaseUrlBox" Background="{ThemeResource InputBackgroundBrush}" Foreground="{ThemeResource TextPrimaryBrush}" BorderBrush="{ThemeResource BorderSubtleBrush}" CornerRadius="8" />
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Spacing="6">
                                            <TextBlock Text="Temperature" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                                            <NumberBox x:Name="ProfileTempBox" Minimum="0" Maximum="2" SpinButtonPlacementMode="Inline" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Spacing="6">
                                            <TextBlock Text="Max Tokens" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                                            <NumberBox x:Name="ProfileMaxTokensBox" Minimum="1" Maximum="128000" SpinButtonPlacementMode="Inline" />
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock Text="User Role" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                                    <TextBox x:Name="ProfileUserRoleBox" Background="{ThemeResource InputBackgroundBrush}" Foreground="{ThemeResource TextPrimaryBrush}" BorderBrush="{ThemeResource BorderSubtleBrush}" CornerRadius="8" />
                                    <TextBlock Text="Profile System Prompt" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                                    <TextBox x:Name="ProfileSystemPromptBox" MinHeight="82" AcceptsReturn="True" TextWrapping="Wrap" Background="{ThemeResource InputBackgroundBrush}" Foreground="{ThemeResource TextPrimaryBrush}" BorderBrush="{ThemeResource BorderSubtleBrush}" CornerRadius="8" />
                                    <CheckBox x:Name="ProfileSharedCheck" Content="Shared in this project" IsChecked="True" Foreground="{ThemeResource TextSecondaryBrush}" />
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                        <Button Click="DeleteProfile_Click" Padding="12,7" Foreground="{ThemeResource DangerBrush}" CornerRadius="8" AutomationProperties.Name="Delete profile">Delete</Button>
                                        <Button Click="SaveProfile_Click" Background="{ThemeResource AccentBrush}" Foreground="{ThemeResource AccentTextBrush}" BorderThickness="0" Padding="16,7" CornerRadius="8" AutomationProperties.Name="Save profile">Save Profile</Button>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <StackPanel x:Name="TemplatesPanel" Visibility="Collapsed" Spacing="10">
                            <Grid x:Name="TemplatesLayoutGrid" ColumnSpacing="12" RowSpacing="12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition x:Name="TemplatesListColumn" Width="230" />
                                    <ColumnDefinition x:Name="TemplateEditorColumn" Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel x:Name="TemplatesListSection" Spacing="8">
                                    <TextBlock Text="Template Library" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}" />
                                    <ListView x:Name="TemplateList" Height="430" DisplayMemberPath="Name" SelectionChanged="TemplateList_SelectionChanged" Background="{ThemeResource SurfaceBrush}" BorderBrush="{ThemeResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="8" AutomationProperties.Name="Prompt templates" />
                                    <Button Click="NewTemplate_Click" Padding="10,7" CornerRadius="8" AutomationProperties.Name="New template">New Template</Button>
                                </StackPanel>
                                <StackPanel x:Name="TemplateEditorSection" Grid.Column="1" Spacing="8">
                                    <TextBlock Text="Name" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                                    <TextBox x:Name="TemplateNameBox" Background="{ThemeResource InputBackgroundBrush}" Foreground="{ThemeResource TextPrimaryBrush}" BorderBrush="{ThemeResource BorderSubtleBrush}" CornerRadius="8" />
                                    <TextBlock Text="Category" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                                    <TextBox x:Name="TemplateCategoryBox" Background="{ThemeResource InputBackgroundBrush}" Foreground="{ThemeResource TextPrimaryBrush}" BorderBrush="{ThemeResource BorderSubtleBrush}" CornerRadius="8" />
                                    <TextBlock Text="Content" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                                    <TextBox x:Name="TemplateContentBox" MinHeight="310" AcceptsReturn="True" TextWrapping="Wrap" Background="{ThemeResource InputBackgroundBrush}" Foreground="{ThemeResource TextPrimaryBrush}" BorderBrush="{ThemeResource BorderSubtleBrush}" CornerRadius="8" />
                                    <CheckBox x:Name="TemplateSharedCheck" Content="Shared in this project" IsChecked="True" Foreground="{ThemeResource TextSecondaryBrush}" />
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                        <Button Click="InsertTemplate_Click" Padding="12,7" CornerRadius="8" AutomationProperties.Name="Insert template into message">Insert</Button>
                                        <Button Click="DeleteTemplate_Click" Padding="12,7" Foreground="{ThemeResource DangerBrush}" CornerRadius="8" AutomationProperties.Name="Delete template">Delete</Button>
                                        <Button Click="SaveTemplate_Click" Background="{ThemeResource AccentBrush}" Foreground="{ThemeResource AccentTextBrush}" BorderThickness="0" Padding="16,7" CornerRadius="8" AutomationProperties.Name="Save template">Save Template</Button>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <StackPanel x:Name="AuditPanel" Visibility="Collapsed" Spacing="10">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Stretch">
                                <TextBlock Text="Audit Log" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}" />
                                <Button Click="RefreshAudit_Click" Margin="16,0,0,0" Padding="10,6" CornerRadius="8" AutomationProperties.Name="Refresh audit log">
                                    <SymbolIcon Symbol="Refresh" />
                                </Button>
                            </StackPanel>
                            <ListView x:Name="AuditList" Height="500" Background="{ThemeResource SurfaceBrush}" BorderBrush="{ThemeResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="8" AutomationProperties.Name="Audit log">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Padding="10,8" Spacing="3">
                                            <TextBlock Text="{Binding Summary}" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}" TextWrapping="Wrap" />
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding EventType}" FontSize="12" Foreground="{ThemeResource AccentBrush}" />
                                                <TextBlock Text="{Binding EntityType}" FontSize="12" Foreground="{ThemeResource TextMutedBrush}" />
                                                <TextBlock Text="{Binding CreatedAt}" FontSize="12" Foreground="{ThemeResource TextMutedBrush}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>

                        <StackPanel x:Name="SyncPanel" Visibility="Collapsed" Spacing="10">
                            <TextBlock Text="Optional Sync Package" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}" />
                            <CheckBox x:Name="CloudSyncCheck" Content="Mark this workspace as sync-enabled" Foreground="{ThemeResource TextSecondaryBrush}" />
                            <TextBlock Text="Sync Folder" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                            <TextBox x:Name="SyncFolderBox" PlaceholderText="Local folder or mounted cloud-drive folder" Background="{ThemeResource InputBackgroundBrush}" Foreground="{ThemeResource TextPrimaryBrush}" BorderBrush="{ThemeResource BorderSubtleBrush}" CornerRadius="8" />
                            <TextBlock Text="Export and import workspace packages for shared prompts, templates, profiles, and norms. API keys are not exported." TextWrapping="Wrap" Foreground="{ThemeResource TextSecondaryBrush}" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Click="SaveProject_Click" Background="{ThemeResource AccentBrush}" Foreground="{ThemeResource AccentTextBrush}" BorderThickness="0" Padding="12,8" CornerRadius="8" AutomationProperties.Name="Save sync settings">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <SymbolIcon Symbol="Accept" />
                                        <TextBlock Text="Save Settings" />
                                    </StackPanel>
                                </Button>
                                <Button Click="ExportWorkspace_Click" Padding="12,8" CornerRadius="8" AutomationProperties.Name="Export workspace package">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <SymbolIcon Symbol="Save" />
                                        <TextBlock Text="Export Package" />
                                    </StackPanel>
                                </Button>
                                <Button Click="ImportWorkspace_Click" Padding="12,8" CornerRadius="8" AutomationProperties.Name="Import workspace package">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <SymbolIcon Symbol="OpenFile" />
                                        <TextBlock Text="Import Package" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</ContentDialog>
