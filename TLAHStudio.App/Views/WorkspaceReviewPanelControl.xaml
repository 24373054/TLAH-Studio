<UserControl
    x:Class="TLAHStudio.App.Views.WorkspaceReviewPanelControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:TLAHStudio.App.Views">
    <UserControl.Resources>
        <views:WorkspaceChangeBrushConverter x:Key="WorkspaceChangeBrushConverter" />
        <views:WorkspaceDiffLineBrushConverter x:Key="WorkspaceDiffLineBrushConverter" />
    </UserControl.Resources>

    <Grid
        x:Name="PanelRoot"
        MinWidth="420"
        Background="{ThemeResource AppChromeBrush}"
        BorderBrush="{ThemeResource BorderSubtleBrush}"
        BorderThickness="1,0,0,0"
        AutomationProperties.Name="Changes and preview workbench">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Padding="18,18,14,14" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="3">
                <TextBlock Text="WORKSPACE REVIEW" FontSize="10" FontWeight="SemiBold" CharacterSpacing="65" Foreground="{ThemeResource TextMutedBrush}" />
                <TextBlock x:Name="WorkspaceNameText" Text="Workspace" FontSize="17" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}" />
                <TextBlock x:Name="SummaryText" Text="Choose a workspace to review local changes." FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis"
                           AutomationProperties.LiveSetting="Polite" />
            </StackPanel>
            <Button
                Grid.Column="1"
                Click="Refresh_Click"
                Style="{StaticResource NocturneIconButtonStyle}"
                ToolTipService.ToolTip="Refresh changes"
                AutomationProperties.Name="Refresh changes">
                <FontIcon Glyph="&#xE72E;" Style="{StaticResource NocturneIconStyle}" />
            </Button>
            <Button
                Grid.Column="2"
                Click="Close_Click"
                Style="{StaticResource NocturneIconButtonStyle}"
                ToolTipService.ToolTip="Close changes"
                AutomationProperties.Name="Close changes">
                <FontIcon Glyph="&#xE72C;" Style="{StaticResource NocturneIconStyle}" />
            </Button>
        </Grid>

        <Border Grid.Row="1" Height="1" Background="{ThemeResource BorderSubtleBrush}" />

        <Grid Grid.Row="2" Padding="14,16,14,18" ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="152" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="CHANGES" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextMutedBrush}" />
            <Grid Grid.Row="0" Grid.Column="1" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="PREVIEW" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextMutedBrush}" />
                <Button
                    Grid.Column="1"
                    Click="CopyDiff_Click"
                    Padding="6,2"
                    Background="Transparent"
                    Foreground="{ThemeResource TextMutedBrush}"
                    BorderThickness="0"
                    ToolTipService.ToolTip="Copy complete diff"
                    AutomationProperties.Name="Copy complete diff">
                    <FontIcon Glyph="&#xE8C8;" FontSize="13" />
                </Button>
            </Grid>

            <ListView
                x:Name="ChangesList"
                Grid.Row="1"
                Margin="0,10,0,0"
                Background="Transparent"
                BorderThickness="0"
                SelectionMode="Single"
                SelectionChanged="ChangesList_SelectionChanged"
                AutomationProperties.Name="Changed files">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="9,8" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding StatusLabel}" FontFamily="Cascadia Mono" FontSize="11" Foreground="{Binding Status, Converter={StaticResource WorkspaceChangeBrushConverter}}" />
                            <TextBlock Grid.Column="1" Text="{Binding Path}" TextWrapping="WrapWholeWords" FontSize="12" Foreground="{ThemeResource TextPrimaryBrush}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,1" />
                        <Setter Property="CornerRadius" Value="8" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>

            <Border
                Grid.Row="1"
                Grid.Column="1"
                Margin="0,10,0,0"
                Padding="2"
                Background="{ThemeResource InputBackgroundBrush}"
                BorderBrush="{ThemeResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <ScrollViewer
                    Padding="0,10,0,10"
                    VerticalScrollBarVisibility="Auto"
                    VerticalScrollMode="Enabled"
                    HorizontalScrollBarVisibility="Auto"
                    HorizontalScrollMode="Enabled"
                    IsScrollInertiaEnabled="True"
                    ZoomMode="Disabled"
                    AutomationProperties.Name="Selected file diff preview">
                    <ItemsRepeater x:Name="DiffLinesRepeater">
                        <ItemsRepeater.Layout>
                            <StackLayout Spacing="0" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate>
                                <Grid MinHeight="20" ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="52" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Text="{Binding Number}"
                                        Padding="8,1,6,1"
                                        HorizontalTextAlignment="Right"
                                        FontFamily="Cascadia Mono"
                                        FontSize="11"
                                        Foreground="{ThemeResource TextMutedBrush}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Text="{Binding Text}"
                                        Padding="0,1,14,1"
                                        FontFamily="Cascadia Mono"
                                        FontSize="12"
                                        TextWrapping="NoWrap"
                                        IsTextSelectionEnabled="True"
                                        Foreground="{Binding Text, Converter={StaticResource WorkspaceDiffLineBrushConverter}}"
                                        AutomationProperties.Name="{Binding AccessibleText}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
