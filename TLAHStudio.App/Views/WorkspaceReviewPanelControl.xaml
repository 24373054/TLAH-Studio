<UserControl
    x:Class="TLAHStudio.App.Views.WorkspaceReviewPanelControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:TLAHStudio.App.Views">
    <UserControl.Resources>
        <views:WorkspaceChangeBrushConverter x:Key="WorkspaceChangeBrushConverter" />
    </UserControl.Resources>

    <Grid
        x:Name="PanelRoot"
        MinWidth="420"
        Background="{ThemeResource AppChromeBrush}"
        BorderBrush="{ThemeResource BorderSubtleBrush}"
        BorderThickness="1,0,0,0"
        AutomationProperties.Name="Changes and preview workbench">
        <Grid.ChildrenTransitions>
            <TransitionCollection>
                <EntranceThemeTransition FromHorizontalOffset="12" IsStaggeringEnabled="False" />
                <RepositionThemeTransition />
            </TransitionCollection>
        </Grid.ChildrenTransitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Padding="18,18,14,14" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="3">
                <TextBlock Text="WORKSPACE REVIEW" FontSize="10" FontWeight="SemiBold" CharacterSpacing="65" Foreground="{ThemeResource TextMutedBrush}" />
                <TextBlock x:Name="WorkspaceNameText" Text="Workspace" FontSize="17" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}" />
                <TextBlock x:Name="SummaryText" Text="Choose a workspace to review local changes." FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis"
                           AutomationProperties.LiveSetting="Polite" />
            </StackPanel>
            <Button
                Grid.Column="1"
                Click="Refresh_Click"
                Style="{StaticResource NocturneIconButtonStyle}"
                ToolTipService.ToolTip="Refresh changes"
                AutomationProperties.Name="Refresh changes">
                <FontIcon Glyph="&#xE72E;" Style="{StaticResource NocturneIconStyle}" />
            </Button>
            <Button
                Grid.Column="2"
                Click="Close_Click"
                Style="{StaticResource NocturneIconButtonStyle}"
                ToolTipService.ToolTip="Close changes"
                AutomationProperties.Name="Close changes">
                <FontIcon Glyph="&#xE72C;" Style="{StaticResource NocturneIconStyle}" />
            </Button>
        </Grid>

        <Border Grid.Row="1" Height="1" Background="{ThemeResource BorderSubtleBrush}" />

        <Grid Grid.Row="2" Padding="14,16,14,18" ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="152" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="CHANGES" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextMutedBrush}" />
            <TextBlock Grid.Row="0" Grid.Column="1" Text="PREVIEW" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextMutedBrush}" />

            <ListView
                x:Name="ChangesList"
                Grid.Row="1"
                Margin="0,10,0,0"
                Background="Transparent"
                BorderThickness="0"
                SelectionMode="Single"
                SelectionChanged="ChangesList_SelectionChanged"
                AutomationProperties.Name="Changed files">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="9,8" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding StatusLabel}" FontFamily="Cascadia Mono" FontSize="11" Foreground="{Binding Status, Converter={StaticResource WorkspaceChangeBrushConverter}}" />
                            <TextBlock Grid.Column="1" Text="{Binding Path}" TextWrapping="WrapWholeWords" FontSize="12" Foreground="{ThemeResource TextPrimaryBrush}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,1" />
                        <Setter Property="CornerRadius" Value="8" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>

            <Border
                Grid.Row="1"
                Grid.Column="1"
                Margin="0,10,0,0"
                Padding="2"
                Background="{ThemeResource InputBackgroundBrush}"
                BorderBrush="{ThemeResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="10">
                <TextBox
                    x:Name="DiffTextBox"
                    IsReadOnly="True"
                    IsSpellCheckEnabled="False"
                    AcceptsReturn="True"
                    TextWrapping="NoWrap"
                    FontFamily="Cascadia Mono"
                    FontSize="12"
                    Padding="14"
                    Background="Transparent"
                    Foreground="{ThemeResource TextPrimaryBrush}"
                    BorderThickness="0"
                    AutomationProperties.Name="Selected file diff preview" />
            </Border>
        </Grid>
    </Grid>
</UserControl>
