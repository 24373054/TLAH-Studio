<UserControl
    x:Class="TLAHStudio.App.Views.WorkspaceReviewPanelControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid
        x:Name="PanelRoot"
        MinWidth="420"
        Background="{ThemeResource AppChromeBrush}"
        BorderBrush="{ThemeResource BorderSubtleBrush}"
        BorderThickness="1,0,0,0"
        AutomationProperties.Name="Changes and preview workbench">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Padding="16,14,12,12" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="2">
                <TextBlock x:Name="WorkspaceNameText" Text="Workspace" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}" />
                <TextBlock x:Name="SummaryText" Text="Choose a workspace to review local changes." FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis"
                           AutomationProperties.LiveSetting="Polite" />
            </StackPanel>
            <Button
                Grid.Column="1"
                Click="Refresh_Click"
                Width="34"
                Height="34"
                Padding="0"
                CornerRadius="8"
                Background="{ThemeResource SurfaceElevatedBrush}"
                Foreground="{ThemeResource TextSecondaryBrush}"
                BorderBrush="{ThemeResource BorderSubtleBrush}"
                ToolTipService.ToolTip="Refresh changes"
                AutomationProperties.Name="Refresh changes">
                <SymbolIcon Symbol="Refresh" />
            </Button>
            <Button
                Grid.Column="2"
                Click="Close_Click"
                Width="34"
                Height="34"
                Padding="0"
                CornerRadius="8"
                Background="{ThemeResource SurfaceElevatedBrush}"
                Foreground="{ThemeResource TextSecondaryBrush}"
                BorderBrush="{ThemeResource BorderSubtleBrush}"
                ToolTipService.ToolTip="Close changes"
                AutomationProperties.Name="Close changes">
                <SymbolIcon Symbol="Forward" />
            </Button>
        </Grid>

        <Border Grid.Row="1" Height="1" Background="{ThemeResource BorderSubtleBrush}" />

        <Grid Grid.Row="2" Padding="12,14,12,16" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="152" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="CHANGES" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextMutedBrush}" />
            <TextBlock Grid.Row="0" Grid.Column="1" Text="PREVIEW" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextMutedBrush}" />

            <ListView
                x:Name="ChangesList"
                Grid.Row="1"
                Margin="0,8,0,0"
                Background="Transparent"
                BorderThickness="0"
                SelectionMode="Single"
                SelectionChanged="ChangesList_SelectionChanged"
                AutomationProperties.Name="Changed files">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="8,7" ColumnSpacing="7">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding StatusLabel}" FontFamily="Cascadia Mono" FontSize="11" Foreground="{ThemeResource AccentBrush}" />
                            <TextBlock Grid.Column="1" Text="{Binding Path}" TextWrapping="WrapWholeWords" FontSize="12" Foreground="{ThemeResource TextPrimaryBrush}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,1" />
                        <Setter Property="CornerRadius" Value="7" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>

            <Border
                Grid.Row="1"
                Grid.Column="1"
                Margin="0,8,0,0"
                Padding="1"
                Background="{ThemeResource InputBackgroundBrush}"
                BorderBrush="{ThemeResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <TextBox
                    x:Name="DiffTextBox"
                    IsReadOnly="True"
                    IsSpellCheckEnabled="False"
                    AcceptsReturn="True"
                    TextWrapping="NoWrap"
                    FontFamily="Cascadia Mono"
                    FontSize="12"
                    Padding="12"
                    Background="Transparent"
                    Foreground="{ThemeResource TextPrimaryBrush}"
                    BorderThickness="0"
                    AutomationProperties.Name="Selected file diff preview" />
            </Border>
        </Grid>
    </Grid>
</UserControl>
