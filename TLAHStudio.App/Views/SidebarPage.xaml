<UserControl
    x:Class="TLAHStudio.App.Views.SidebarPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:TLAHStudio.App.Views"
    x:Name="SidebarRoot"
    Width="296">

    <UserControl.Resources>
        <DataTemplate x:Key="ChatItemTemplate">
            <Grid Padding="13,10" ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid
                    Grid.Column="0"
                    Width="24"
                    Height="24"
                    VerticalAlignment="Center">
                    <FontIcon
                        Glyph="&#xE8BD;"
                        Style="{StaticResource NocturneIconStyle}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
                </Grid>

                <StackPanel Grid.Column="1" Spacing="3">
                    <TextBlock
                        Text="{Binding Title}"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextPrimaryBrush}"
                        TextTrimming="CharacterEllipsis" />
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock
                            Text="{Binding MessageCount}"
                            FontSize="12"
                            Foreground="{ThemeResource TextMutedBrush}" />
                        <TextBlock
                            Text="messages"
                            FontSize="12"
                            Foreground="{ThemeResource TextMutedBrush}" />
                    </StackPanel>
                </StackPanel>

                <Button
                    Grid.Column="2"
                    Width="32"
                    Height="32"
                    Padding="0"
                    Background="{ThemeResource SurfaceElevatedBrush}"
                    Foreground="{ThemeResource TextMutedBrush}"
                    BorderBrush="{ThemeResource BorderSubtleBrush}"
                    CornerRadius="8"
                    ToolTipService.ToolTip="Chat actions"
                    AutomationProperties.Name="Chat actions">
                    <FontIcon Glyph="&#xE712;" Style="{StaticResource NocturneIconStyle}" />
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Text="Pin or unpin" Tag="{Binding}" Click="PinChat_Click">
                                <MenuFlyoutItem.Icon>
                                    <SymbolIcon Symbol="Pin" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem Text="Rename" Tag="{Binding}" Click="RenameChat_Click">
                                <MenuFlyoutItem.Icon>
                                    <SymbolIcon Symbol="Edit" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem Text="Archive or restore" Tag="{Binding}" Click="ArchiveChat_Click">
                                <MenuFlyoutItem.Icon>
                                    <SymbolIcon Symbol="Folder" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem Text="Export JSON" Tag="{Binding}" Click="ExportChat_Click">
                                <MenuFlyoutItem.Icon>
                                    <SymbolIcon Symbol="Save" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutSeparator />
                            <MenuFlyoutItem Text="Delete" Tag="{Binding}" Click="DeleteChat_Click" Foreground="{ThemeResource DangerBrush}">
                                <MenuFlyoutItem.Icon>
                                    <SymbolIcon Symbol="Delete" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="CompactChatItemTemplate">
            <Grid
                Width="48"
                Height="48"
                HorizontalAlignment="Center"
                ToolTipService.ToolTip="{Binding Title}">
                <SymbolIcon
                    Symbol="Message"
                    Foreground="{ThemeResource TextSecondaryBrush}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center" />
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="SidebarSectionTemplate">
            <TextBlock Text="{Binding Header}" Margin="8,12,8,3" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextMutedBrush}" />
        </DataTemplate>
        <DataTemplate x:Key="VirtualizedChatItemTemplate">
            <Grid Padding="13,10" ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <FontIcon Glyph="&#xE8BD;" Style="{StaticResource NocturneIconStyle}" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Spacing="3">
                    <TextBlock Text="{Binding Chat.Title}" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="{Binding Chat.MessageCount}" FontSize="12" Foreground="{ThemeResource TextMutedBrush}" />
                        <TextBlock Text="messages" FontSize="12" Foreground="{ThemeResource TextMutedBrush}" />
                    </StackPanel>
                </StackPanel>
                <Button Grid.Column="2" Width="32" Height="32" Padding="0" Background="{ThemeResource SurfaceElevatedBrush}" Foreground="{ThemeResource TextMutedBrush}" BorderBrush="{ThemeResource BorderSubtleBrush}" CornerRadius="8" ToolTipService.ToolTip="Chat actions" AutomationProperties.Name="Chat actions">
                    <FontIcon Glyph="&#xE712;" Style="{StaticResource NocturneIconStyle}" />
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Text="Pin or unpin" Tag="{Binding Chat}" Click="PinChat_Click"><MenuFlyoutItem.Icon><SymbolIcon Symbol="Pin" /></MenuFlyoutItem.Icon></MenuFlyoutItem>
                            <MenuFlyoutItem Text="Rename" Tag="{Binding Chat}" Click="RenameChat_Click"><MenuFlyoutItem.Icon><SymbolIcon Symbol="Edit" /></MenuFlyoutItem.Icon></MenuFlyoutItem>
                            <MenuFlyoutItem Text="Archive or restore" Tag="{Binding Chat}" Click="ArchiveChat_Click"><MenuFlyoutItem.Icon><SymbolIcon Symbol="Folder" /></MenuFlyoutItem.Icon></MenuFlyoutItem>
                            <MenuFlyoutItem Text="Export JSON" Tag="{Binding Chat}" Click="ExportChat_Click"><MenuFlyoutItem.Icon><SymbolIcon Symbol="Save" /></MenuFlyoutItem.Icon></MenuFlyoutItem>
                            <MenuFlyoutSeparator />
                            <MenuFlyoutItem Text="Delete" Tag="{Binding Chat}" Click="DeleteChat_Click" Foreground="{ThemeResource DangerBrush}"><MenuFlyoutItem.Icon><SymbolIcon Symbol="Delete" /></MenuFlyoutItem.Icon></MenuFlyoutItem>
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
            </Grid>
        </DataTemplate>
        <DataTemplate x:Key="VirtualizedCompactChatItemTemplate">
            <Grid Width="48" Height="48" HorizontalAlignment="Center" ToolTipService.ToolTip="{Binding Chat.Title}">
                <FontIcon Glyph="&#xE8BD;" Style="{StaticResource NocturneIconStyle}" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Grid>
        </DataTemplate>
        <views:SidebarEntryTemplateSelector
            x:Key="SidebarEntryTemplateSelector"
            HeaderTemplate="{StaticResource SidebarSectionTemplate}"
            ChatTemplate="{StaticResource VirtualizedChatItemTemplate}"
            CompactChatTemplate="{StaticResource VirtualizedCompactChatItemTemplate}" />
    </UserControl.Resources>

        <Grid Background="{ThemeResource PanelBrush}">
        <Grid.ChildrenTransitions>
            <TransitionCollection>
                <EntranceThemeTransition FromHorizontalOffset="-8" IsStaggeringEnabled="False" />
                <RepositionThemeTransition />
            </TransitionCollection>
        </Grid.ChildrenTransitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="SidebarHeader"
            Grid.Row="0"
            Padding="18,16,16,14"
            BorderBrush="{ThemeResource BorderSubtleBrush}"
            BorderThickness="0,0,0,1">
            <Grid x:Name="BrandHeaderGrid" ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border
                    Width="32"
                    Height="32"
                    Background="{ThemeResource BrandMarkBrush}"
                    BorderBrush="{ThemeResource AccentSecondaryBrush}"
                    BorderThickness="1"
                    CornerRadius="9">
                    <Image
                        Source="ms-appx:///Assets/logo.png"
                        Width="21"
                        Height="21"
                        Stretch="Uniform"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
                </Border>

                <StackPanel x:Name="BrandTextPanel" Grid.Column="1" Spacing="2">
                    <TextBlock
                        Text="TLAH Studio"
                        FontSize="19"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextPrimaryBrush}" />
                    <TextBlock
                        Text="AGENT WORKSPACE"
                        FontSize="10"
                        FontWeight="SemiBold"
                        CharacterSpacing="65"
                        Foreground="{ThemeResource TextMutedBrush}" />
                </StackPanel>

                <Button
                    x:Name="CollapseButton"
                    Grid.Column="2"
                    Click="Collapse_Click"
                    Width="32"
                    Height="32"
                    Padding="0"
                    Background="Transparent"
                    Foreground="{ThemeResource TextMutedBrush}"
                    BorderThickness="0"
                    CornerRadius="8"
                    ToolTipService.ToolTip="Collapse sidebar"
                    AutomationProperties.Name="Collapse sidebar">
                    <FontIcon x:Name="CollapseIcon" Glyph="&#xE72D;" Style="{StaticResource NocturneIconStyle}" />
                </Button>
            </Grid>
        </Grid>

        <StackPanel
            Grid.Row="1"
            Padding="14,12,14,10"
            Spacing="9">
            <Button
                x:Name="NewChatButton"
                Click="NewChat_Click"
                Background="{ThemeResource AccentStrongBrush}"
                Foreground="{ThemeResource AccentTextBrush}"
                BorderBrush="{ThemeResource AccentStrongBrush}"
                CornerRadius="10"
                Padding="14,10"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Left"
                TabIndex="1"
                AutomationProperties.Name="New chat">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE710;" FontFamily="Segoe Fluent Icons" FontSize="16" Foreground="{ThemeResource AccentTextBrush}" />
                    <TextBlock x:Name="NewChatText" Text="New Chat" FontWeight="SemiBold" />
                </StackPanel>
            </Button>

            <Grid x:Name="SearchToolsGrid" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox
                    x:Name="SearchBox"
                    PlaceholderText="Search chats"
                    MinHeight="38"
                    Background="{ThemeResource InputBackgroundBrush}"
                    Foreground="{ThemeResource TextPrimaryBrush}"
                    BorderBrush="{ThemeResource BorderSubtleBrush}"
                    CornerRadius="9"
                    TextChanged="SearchBox_TextChanged"
                    TabIndex="2"
                    AutomationProperties.Name="Search chats" />
                <ToggleButton
                    x:Name="ArchivedToggle"
                    Grid.Column="1"
                    Click="ArchivedToggle_Click"
                    Background="{ThemeResource SurfaceElevatedBrush}"
                    Foreground="{ThemeResource TextSecondaryBrush}"
                    BorderBrush="{ThemeResource BorderSubtleBrush}"
                    CornerRadius="9"
                    MinWidth="38"
                    MinHeight="38"
                    Padding="10,6"
                    ToolTipService.ToolTip="Show archived chats"
                    TabIndex="3"
                    AutomationProperties.Name="Show archived chats">
                    <SymbolIcon Symbol="Folder" />
                </ToggleButton>
            </Grid>
        </StackPanel>

        <ScrollViewer
            Visibility="Collapsed"
            Grid.Row="2"
            Padding="10,0,10,10"
            VerticalScrollBarVisibility="Auto"
            VerticalScrollMode="Enabled"
            HorizontalScrollBarVisibility="Disabled"
            HorizontalScrollMode="Disabled">
            <StackPanel Spacing="10">
                <StackPanel x:Name="PinnedSection" Spacing="4">
                    <TextBlock
                        x:Name="PinnedSectionTitle"
                        Text="Pinned"
                        Margin="8,4,8,0"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextMutedBrush}" />
                    <ListView
                        x:Name="PinnedListView"
                        Background="Transparent"
                        SelectionMode="Single"
                        IsItemClickEnabled="False"
                        SelectionChanged="ChatList_SelectionChanged"
                        ItemTemplate="{StaticResource ChatItemTemplate}">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Margin" Value="0,2" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="MinHeight" Value="62" />
                                <Setter Property="CornerRadius" Value="8" />
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                </StackPanel>

                <!-- M4.7.0: Date-grouped chat sections -->
                <StackPanel x:Name="TodaySection" Spacing="4" Visibility="Collapsed">
                    <TextBlock Text="Today" Margin="8,4,8,0" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextMutedBrush}" />
                    <ListView x:Name="TodayListView" ItemsSource="" Background="Transparent" SelectionMode="Single" IsItemClickEnabled="False" SelectionChanged="ChatList_SelectionChanged" ItemTemplate="{StaticResource ChatItemTemplate}" AutomationProperties.Name="Today chats">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Margin" Value="0,2" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="MinHeight" Value="62" />
                                <Setter Property="CornerRadius" Value="8" />
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                </StackPanel>
                <StackPanel x:Name="YesterdaySection" Spacing="4" Visibility="Collapsed">
                    <TextBlock Text="Yesterday" Margin="8,4,8,0" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextMutedBrush}" />
                    <ListView x:Name="YesterdayListView" ItemsSource="" Background="Transparent" SelectionMode="Single" IsItemClickEnabled="False" SelectionChanged="ChatList_SelectionChanged" ItemTemplate="{StaticResource ChatItemTemplate}" AutomationProperties.Name="Yesterday chats">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Margin" Value="0,2" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="MinHeight" Value="62" />
                                <Setter Property="CornerRadius" Value="8" />
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                </StackPanel>
                <StackPanel x:Name="ThisWeekSection" Spacing="4" Visibility="Collapsed">
                    <TextBlock Text="This Week" Margin="8,4,8,0" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextMutedBrush}" />
                    <ListView x:Name="ThisWeekListView" ItemsSource="" Background="Transparent" SelectionMode="Single" IsItemClickEnabled="False" SelectionChanged="ChatList_SelectionChanged" ItemTemplate="{StaticResource ChatItemTemplate}" AutomationProperties.Name="This week chats">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Margin" Value="0,2" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="MinHeight" Value="62" />
                                <Setter Property="CornerRadius" Value="8" />
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                </StackPanel>
                <StackPanel x:Name="OlderSection" Spacing="4" Visibility="Collapsed">
                    <TextBlock Text="Older" Margin="8,4,8,0" FontSize="11" FontWeight="SemiBold" Foreground="{ThemeResource TextMutedBrush}" />
                    <ListView x:Name="OlderListView" ItemsSource="" Background="Transparent" SelectionMode="Single" IsItemClickEnabled="False" SelectionChanged="ChatList_SelectionChanged" ItemTemplate="{StaticResource ChatItemTemplate}" AutomationProperties.Name="Older chats">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Margin" Value="0,2" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="MinHeight" Value="62" />
                                <Setter Property="CornerRadius" Value="8" />
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                </StackPanel>

                <Border
                    x:Name="EmptyListState"
                    Visibility="Collapsed"
                    Padding="16,18"
                    Background="{ThemeResource PanelAltBrush}"
                    BorderBrush="{ThemeResource BorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="0,8,0,0">
                    <StackPanel Spacing="6">
                        <TextBlock
                            x:Name="EmptyListTitle"
                            Text="No chats found"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource TextPrimaryBrush}" />
                        <TextBlock
                            x:Name="EmptyListBody"
                            Text="Create a new chat or clear the current search."
                            TextWrapping="Wrap"
                            FontSize="12"
                            Foreground="{ThemeResource TextSecondaryBrush}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Padding="10,0,10,10">
            <ListView
                x:Name="ChatListView"
                Background="Transparent"
                BorderThickness="0"
                SelectionMode="Single"
                SelectionChanged="ChatList_SelectionChanged"
                ItemTemplateSelector="{StaticResource SidebarEntryTemplateSelector}"
                AutomationProperties.Name="Chats">
                <ListView.ItemContainerTransitions>
                    <TransitionCollection>
                        <AddDeleteThemeTransition />
                        <RepositionThemeTransition />
                    </TransitionCollection>
                </ListView.ItemContainerTransitions>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Margin" Value="0,1" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="MinHeight" Value="36" />
                        <Setter Property="CornerRadius" Value="9" />
                    </Style>
                </ListView.ItemContainerStyle>
            </ListView>
            <Border
                x:Name="VirtualizedEmptyListState"
                Visibility="Collapsed"
                Padding="16,18"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top"
                Margin="0,12,0,0"
                Background="{ThemeResource PanelAltBrush}"
                BorderBrush="{ThemeResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="6">
                    <TextBlock x:Name="VirtualizedEmptyListTitle" Text="No chats found" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}" />
                    <TextBlock x:Name="VirtualizedEmptyListBody" Text="Create a new chat or clear the current search." TextWrapping="Wrap" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid
            x:Name="UndoDeletePanel"
            Grid.Row="3"
            Padding="12,0,12,10"
            Visibility="Collapsed">
            <Border
                Padding="10"
                Background="{ThemeResource SurfaceElevatedBrush}"
                BorderBrush="{ThemeResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        x:Name="UndoDeleteText"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextSecondaryBrush}"
                        TextTrimming="CharacterEllipsis" />
                    <Button
                        Grid.Column="1"
                        Click="UndoDelete_Click"
                        Padding="10,5"
                        CornerRadius="8"
                        Content="Undo"
                        AutomationProperties.Name="Undo delete chat" />
                </Grid>
            </Border>
        </Grid>

        <StackPanel
            x:Name="ExpandedFooter"
            Grid.Row="4"
            Padding="14"
            Spacing="8"
            BorderBrush="{ThemeResource BorderSubtleBrush}"
            BorderThickness="0,1,0,0">
            <Grid ColumnSpacing="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button
                    Click="Settings_Click"
                    Background="Transparent"
                    Foreground="{ThemeResource TextSecondaryBrush}"
                    BorderThickness="0"
                    Padding="8,7"
                    HorizontalAlignment="Stretch"
                    AutomationProperties.Name="Settings">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <SymbolIcon Symbol="Setting" />
                        <TextBlock Text="Settings" />
                    </StackPanel>
                </Button>
                <Button
                    Grid.Column="1"
                    Click="About_Click"
                    Background="Transparent"
                    Foreground="{ThemeResource TextSecondaryBrush}"
                    BorderThickness="0"
                    Padding="8,7"
                    HorizontalAlignment="Stretch"
                    AutomationProperties.Name="About release">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <SymbolIcon Symbol="ContactInfo" />
                        <TextBlock Text="About" />
                    </StackPanel>
                </Button>
            </Grid>
            <Grid ColumnSpacing="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button
                    Click="CheckUpdate_Click"
                    Background="Transparent"
                    Foreground="{ThemeResource TextSecondaryBrush}"
                    BorderThickness="0"
                    Padding="8,7"
                    HorizontalAlignment="Stretch"
                    AutomationProperties.Name="Check for updates">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <SymbolIcon Symbol="Sync" />
                        <TextBlock Text="Update" />
                    </StackPanel>
                </Button>
                <Button
                    Grid.Column="1"
                    Click="Density_Click"
                    Background="Transparent"
                    Foreground="{ThemeResource TextSecondaryBrush}"
                    BorderThickness="0"
                    Padding="8,7"
                    HorizontalAlignment="Stretch"
                    AutomationProperties.Name="Toggle density">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <SymbolIcon Symbol="View" />
                        <TextBlock x:Name="DensityButtonText" Text="Comfort" />
                    </StackPanel>
                </Button>
            </Grid>
            <Button
                Click="Workspace_Click"
                Background="Transparent"
                Foreground="{ThemeResource TextSecondaryBrush}"
                BorderThickness="0"
                Padding="8,7"
                HorizontalAlignment="Stretch"
                AutomationProperties.Name="Workspace">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <SymbolIcon Symbol="People" />
                    <TextBlock Text="Workspace" />
                </StackPanel>
            </Button>
            <Button
                Click="Tools_Click"
                Background="Transparent"
                Foreground="{ThemeResource TextSecondaryBrush}"
                BorderThickness="0"
                Padding="8,7"
                HorizontalAlignment="Stretch"
                AutomationProperties.Name="Tools and security">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <SymbolIcon Symbol="Permissions" />
                    <TextBlock Text="Tools &amp; Security" />
                </StackPanel>
            </Button>
            <Button
                Click="Privacy_Click"
                Background="Transparent"
                Foreground="{ThemeResource TextSecondaryBrush}"
                BorderThickness="0"
                Padding="8,7"
                HorizontalAlignment="Stretch"
                AutomationProperties.Name="Privacy and data">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <SymbolIcon Symbol="Document" />
                    <TextBlock Text="Privacy &amp; Data" />
                </StackPanel>
            </Button>
        </StackPanel>

        <StackPanel
            x:Name="CompactFooter"
            Grid.Row="4"
            Visibility="Collapsed"
            Padding="10,12"
            Spacing="6"
            BorderBrush="{ThemeResource BorderSubtleBrush}"
            BorderThickness="0,1,0,0">
            <Button
                Click="Settings_Click"
                Width="44"
                Height="40"
                Padding="0"
                Background="Transparent"
                Foreground="{ThemeResource TextSecondaryBrush}"
                BorderThickness="0"
                CornerRadius="8"
                ToolTipService.ToolTip="Settings"
                AutomationProperties.Name="Settings">
                <SymbolIcon Symbol="Setting" />
            </Button>
            <Button
                Click="Workspace_Click"
                Width="44"
                Height="40"
                Padding="0"
                Background="Transparent"
                Foreground="{ThemeResource TextSecondaryBrush}"
                BorderThickness="0"
                CornerRadius="8"
                ToolTipService.ToolTip="Workspace"
                AutomationProperties.Name="Workspace">
                <SymbolIcon Symbol="People" />
            </Button>
            <Button
                Click="Tools_Click"
                Width="44"
                Height="40"
                Padding="0"
                Background="Transparent"
                Foreground="{ThemeResource TextSecondaryBrush}"
                BorderThickness="0"
                CornerRadius="8"
                ToolTipService.ToolTip="Tools and security"
                AutomationProperties.Name="Tools and security">
                <SymbolIcon Symbol="Permissions" />
            </Button>
            <Button
                Click="Privacy_Click"
                Width="44"
                Height="40"
                Padding="0"
                Background="Transparent"
                Foreground="{ThemeResource TextSecondaryBrush}"
                BorderThickness="0"
                CornerRadius="8"
                ToolTipService.ToolTip="Privacy and data"
                AutomationProperties.Name="Privacy and data">
                <SymbolIcon Symbol="Document" />
            </Button>
            <Button
                Width="44"
                Height="40"
                Padding="0"
                Background="Transparent"
                Foreground="{ThemeResource TextSecondaryBrush}"
                BorderThickness="0"
                CornerRadius="8"
                ToolTipService.ToolTip="More"
                AutomationProperties.Name="More sidebar commands">
                <SymbolIcon Symbol="More" />
                <Button.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="Check for updates" Click="CheckUpdate_Click">
                            <MenuFlyoutItem.Icon><SymbolIcon Symbol="Sync" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="Toggle density" Click="Density_Click">
                            <MenuFlyoutItem.Icon><SymbolIcon Symbol="View" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem Text="About" Click="About_Click">
                            <MenuFlyoutItem.Icon><SymbolIcon Symbol="ContactInfo" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </Button.Flyout>
            </Button>
        </StackPanel>
    </Grid>

</UserControl>
