<UserControl
    x:Class="TLAHStudio.App.Views.ChatHeaderControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid
        Padding="26,16,22,14"
        Background="{ThemeResource AppChromeBrush}"
        BorderBrush="{ThemeResource BorderSubtleBrush}"
        BorderThickness="0,0,0,1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock
            x:Name="TitleBlock"
            Grid.Column="0"
            Text="Select a chat"
            FontSize="18"
            FontWeight="SemiBold"
            Foreground="{ThemeResource TextPrimaryBrush}"
            VerticalAlignment="Center"
            TextTrimming="CharacterEllipsis"
            Tapped="Title_Tapped"
            ToolTipService.ToolTip="Edit title"
            AutomationProperties.Name="Chat title" />

        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
            <Button
                Click="Theme_Click"
                Width="38"
                Height="38"
                Background="{ThemeResource SurfaceElevatedBrush}"
                Foreground="{ThemeResource TextSecondaryBrush}"
                BorderBrush="{ThemeResource BorderSubtleBrush}"
                CornerRadius="8"
                Padding="0"
                ToolTipService.ToolTip="Toggle theme"
                AutomationProperties.Name="Toggle theme">
                <SymbolIcon Symbol="Switch" />
            </Button>
            <Button
                Click="SystemPrompt_Click"
                Width="38"
                Height="38"
                Background="{ThemeResource SurfaceElevatedBrush}"
                Foreground="{ThemeResource TextSecondaryBrush}"
                BorderBrush="{ThemeResource BorderSubtleBrush}"
                CornerRadius="8"
                Padding="0"
                ToolTipService.ToolTip="System prompt"
                AutomationProperties.Name="System prompt">
                <SymbolIcon Symbol="Edit" />
            </Button>
            <Button
                Click="Background_Click"
                Width="38"
                Height="38"
                Background="{ThemeResource SurfaceElevatedBrush}"
                Foreground="{ThemeResource TextSecondaryBrush}"
                BorderBrush="{ThemeResource BorderSubtleBrush}"
                CornerRadius="8"
                Padding="0"
                ToolTipService.ToolTip="Background"
                AutomationProperties.Name="Background settings">
                <SymbolIcon Symbol="Pictures" />
            </Button>
            <Button
                x:Name="ActivityButton"
                Click="Activity_Click"
                Width="38"
                Height="38"
                Background="{ThemeResource SurfaceElevatedBrush}"
                Foreground="{ThemeResource TextSecondaryBrush}"
                BorderBrush="{ThemeResource BorderSubtleBrush}"
                CornerRadius="8"
                Padding="0"
                ToolTipService.ToolTip="Agent activity"
                AutomationProperties.Name="Agent activity">
                <SymbolIcon Symbol="List" />
            </Button>
            <Button
                Click="Agent_Click"
                Width="38"
                Height="38"
                Background="{ThemeResource SurfaceElevatedBrush}"
                Foreground="{ThemeResource TextSecondaryBrush}"
                BorderBrush="{ThemeResource BorderSubtleBrush}"
                CornerRadius="8"
                Padding="0"
                ToolTipService.ToolTip="AGENT.md"
                AutomationProperties.Name="Agent file">
                <SymbolIcon Symbol="Document" />
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
