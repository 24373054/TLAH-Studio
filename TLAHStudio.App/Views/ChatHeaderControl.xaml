<UserControl
    x:Class="TLAHStudio.App.Views.ChatHeaderControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid
        Padding="26,16,22,14"
        Background="{ThemeResource AppChromeBrush}"
        BorderBrush="{ThemeResource BorderSubtleBrush}"
        BorderThickness="0,0,0,1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <StackPanel
            Grid.Column="0"
            VerticalAlignment="Center"
            Spacing="2">
            <TextBlock
                x:Name="TitleBlock"
                Text="Select a chat"
                FontSize="18"
                FontWeight="SemiBold"
                Foreground="{ThemeResource TextPrimaryBrush}"
                TextTrimming="CharacterEllipsis"
                Tapped="Title_Tapped"
                ToolTipService.ToolTip="Edit title"
                AutomationProperties.Name="Chat title" />
            <TextBlock
                x:Name="ContextUsageBlock"
                Text="Context --"
                FontSize="12"
                Foreground="{ThemeResource TextMutedBrush}"
                TextTrimming="CharacterEllipsis"
                AutomationProperties.Name="Context usage" />
            <!-- M4.7.0: Colored segmented context gauge -->
            <Border
                x:Name="ContextGauge"
                Height="4"
                Margin="0,4,0,0"
                CornerRadius="2"
                Background="{ThemeResource BorderSubtleBrush}"
                Visibility="Collapsed">
                <Grid x:Name="ContextGaugeGrid" ColumnSpacing="1" />
            </Border>
            <!-- M4.9.5 Phase F1: compact warning — shown when context > 80%. -->
            <TextBlock
                x:Name="CompactWarn"
                Text="⚠ Context near limit — consider compacting"
                FontSize="11"
                FontWeight="SemiBold"
                Foreground="{ThemeResource DangerBrush}"
                Margin="0,4,0,0"
                Visibility="Collapsed"
                AutomationProperties.Name="Context near limit warning" />
        </StackPanel>

        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
            <Button
                Click="Theme_Click"
                Width="38"
                Height="38"
                Background="{ThemeResource SurfaceElevatedBrush}"
                Foreground="{ThemeResource TextSecondaryBrush}"
                BorderBrush="{ThemeResource BorderSubtleBrush}"
                CornerRadius="8"
                Padding="0"
                ToolTipService.ToolTip="Toggle theme"
                AutomationProperties.Name="Toggle theme">
                <SymbolIcon Symbol="Switch" />
            </Button>
            <Button
                Click="SystemPrompt_Click"
                Width="38"
                Height="38"
                Background="{ThemeResource SurfaceElevatedBrush}"
                Foreground="{ThemeResource TextSecondaryBrush}"
                BorderBrush="{ThemeResource BorderSubtleBrush}"
                CornerRadius="8"
                Padding="0"
                ToolTipService.ToolTip="System prompt"
                AutomationProperties.Name="System prompt">
                <SymbolIcon Symbol="Edit" />
            </Button>
            <Button
                Click="Background_Click"
                Width="38"
                Height="38"
                Background="{ThemeResource SurfaceElevatedBrush}"
                Foreground="{ThemeResource TextSecondaryBrush}"
                BorderBrush="{ThemeResource BorderSubtleBrush}"
                CornerRadius="8"
                Padding="0"
                ToolTipService.ToolTip="Background"
                AutomationProperties.Name="Background settings">
                <SymbolIcon Symbol="Pictures" />
            </Button>
            <Button
                x:Name="ActivityButton"
                Click="Activity_Click"
                Width="38"
                Height="38"
                Background="{ThemeResource SurfaceElevatedBrush}"
                Foreground="{ThemeResource TextSecondaryBrush}"
                BorderBrush="{ThemeResource BorderSubtleBrush}"
                CornerRadius="8"
                Padding="0"
                ToolTipService.ToolTip="Agent activity"
                AutomationProperties.Name="Agent activity">
                <SymbolIcon Symbol="List" />
            </Button>
            <Button
                x:Name="ChangesButton"
                Click="Changes_Click"
                Width="38"
                Height="38"
                Background="{ThemeResource SurfaceElevatedBrush}"
                Foreground="{ThemeResource TextSecondaryBrush}"
                BorderBrush="{ThemeResource BorderSubtleBrush}"
                CornerRadius="8"
                Padding="0"
                ToolTipService.ToolTip="Changes and preview"
                AutomationProperties.Name="Changes and preview">
                <SymbolIcon Symbol="Document" />
            </Button>
            <Button
                Click="Agent_Click"
                Width="38"
                Height="38"
                Background="{ThemeResource SurfaceElevatedBrush}"
                Foreground="{ThemeResource TextSecondaryBrush}"
                BorderBrush="{ThemeResource BorderSubtleBrush}"
                CornerRadius="8"
                Padding="0"
                ToolTipService.ToolTip="AGENT.md"
                AutomationProperties.Name="Agent file">
                <SymbolIcon Symbol="Document" />
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
