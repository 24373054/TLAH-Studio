<UserControl
    x:Class="TLAHStudio.App.Views.MessageInputControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid
        x:Name="InputRoot"
        Padding="22,15"
        Background="{ThemeResource InputDockBrush}"
        BorderBrush="{ThemeResource BorderSubtleBrush}"
        BorderThickness="0,1,0,0">
        <Grid.ChildrenTransitions>
            <TransitionCollection>
                <RepositionThemeTransition />
            </TransitionCollection>
        </Grid.ChildrenTransitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Button
            x:Name="RoleButton"
            Grid.Column="0"
            Width="46"
            MinWidth="46"
            MinHeight="46"
            Margin="0,0,12,0"
            Background="{ThemeResource InputBackgroundBrush}"
            Foreground="{ThemeResource TextPrimaryBrush}"
            BorderBrush="{ThemeResource BorderSubtleBrush}"
            CornerRadius="8"
            Padding="0"
            TabIndex="10"
            ToolTipService.ToolTip="Role: user"
            AutomationProperties.Name="Message role">
            <Button.Flyout>
                <MenuFlyout>
                    <MenuFlyoutItem
                        x:Name="UserRoleItem"
                        Text="user"
                        Click="UserRole_Click" />
                    <MenuFlyoutItem
                        x:Name="SystemRoleItem"
                        Text="system"
                        Click="SystemRole_Click" />
                </MenuFlyout>
            </Button.Flyout>
            <SymbolIcon Symbol="Contact" />
        </Button>

        <Button
            x:Name="AgentModeButton"
            Grid.Column="1"
            MinWidth="46"
            MinHeight="46"
            Margin="0,0,12,0"
            Background="{ThemeResource InputBackgroundBrush}"
            Foreground="{ThemeResource TextPrimaryBrush}"
            BorderBrush="{ThemeResource BorderSubtleBrush}"
            CornerRadius="8"
            Padding="0"
            TabIndex="11"
            Click="AgentMode_Click"
            ToolTipService.ToolTip="Agent mode runs approved sandbox commands for multi-step tasks"
            AutomationProperties.Name="Agent mode">
            <StackPanel Orientation="Horizontal" Spacing="7">
                <SymbolIcon Symbol="Play" />
                <TextBlock x:Name="AgentModeLabel" Text="Agent" FontWeight="SemiBold" />
            </StackPanel>
        </Button>

        <Button
            x:Name="WorkspaceButton"
            Grid.Column="2"
            MinWidth="46"
            MinHeight="46"
            Margin="0,0,12,0"
            Background="{ThemeResource InputBackgroundBrush}"
            Foreground="{ThemeResource TextPrimaryBrush}"
            BorderBrush="{ThemeResource BorderSubtleBrush}"
            CornerRadius="8"
            Padding="0"
            TabIndex="12"
            ToolTipService.ToolTip="Workspace"
            AutomationProperties.Name="Workspace">
            <Button.Flyout>
                <MenuFlyout>
                    <MenuFlyoutItem
                        x:Name="NewWorkspaceItem"
                        Text="New workspace"
                        Click="NewWorkspace_Click" />
                    <MenuFlyoutItem
                        x:Name="ChooseWorkspaceItem"
                        Text="Choose folder"
                        Click="ChooseWorkspace_Click" />
                    <MenuFlyoutSeparator />
                    <MenuFlyoutItem
                        x:Name="OpenWorkspaceItem"
                        Text="Open folder"
                        Click="OpenWorkspace_Click" />
                    <MenuFlyoutItem
                        x:Name="UseSandboxItem"
                        Text="Use sandbox"
                        Click="UseSandbox_Click" />
                </MenuFlyout>
            </Button.Flyout>
            <StackPanel Orientation="Horizontal" Spacing="7">
                <SymbolIcon Symbol="Folder" />
                <TextBlock x:Name="WorkspaceLabel" Text="Sandbox" TextTrimming="CharacterEllipsis" MaxWidth="100" />
            </StackPanel>
        </Button>

        <Button
            x:Name="PermissionModeButton"
            Grid.Column="3"
            MinWidth="46"
            MinHeight="46"
            Margin="0,0,12,0"
            Background="{ThemeResource InputBackgroundBrush}"
            Foreground="{ThemeResource TextPrimaryBrush}"
            BorderBrush="{ThemeResource BorderSubtleBrush}"
            CornerRadius="8"
            Padding="0"
            TabIndex="13"
            ToolTipService.ToolTip="Agent permission mode"
            AutomationProperties.Name="Agent permission mode">
            <Button.Flyout>
                <MenuFlyout>
                    <MenuFlyoutItem
                        x:Name="FullAccessItem"
                        Text="Full access"
                        Click="FullAccess_Click" />
                    <MenuFlyoutItem
                        x:Name="AutoApproveItem"
                        Text="Auto approve"
                        Click="AutoApprove_Click" />
                    <!-- M4.9.0: Plan mode -->
                    <MenuFlyoutItem
                        x:Name="PlanItem"
                        Text="Plan"
                        Click="Plan_Click" />
                    <MenuFlyoutItem
                        x:Name="AskApprovalItem"
                        Text="Ask"
                        Click="AskApproval_Click" />
                </MenuFlyout>
            </Button.Flyout>
            <StackPanel Orientation="Horizontal" Spacing="7">
                <SymbolIcon Symbol="Permissions" />
                <TextBlock x:Name="PermissionModeLabel" Text="Ask" FontWeight="SemiBold" />
            </StackPanel>
        </Button>

        <TextBox
            x:Name="InputBox"
            Grid.Column="4"
            MinHeight="46"
            MaxHeight="160"
            AcceptsReturn="True"
            InputScope="Text"
            TextWrapping="Wrap"
            ScrollViewer.VerticalScrollBarVisibility="Auto"
            PlaceholderText="Type a message... (Shift+Enter for new line)"
            Background="{ThemeResource InputBackgroundBrush}"
            Foreground="{ThemeResource TextPrimaryBrush}"
            BorderBrush="{ThemeResource BorderSubtleBrush}"
            CornerRadius="8"
            Padding="14,10"
            TabIndex="14"
            AutomationProperties.Name="Message input" />

        <!-- M4.7.0: Character counter -->
        <TextBlock
            x:Name="CharCounter"
            Grid.Column="4"
            HorizontalAlignment="Right"
            VerticalAlignment="Bottom"
            Margin="0,0,4,4"
            FontSize="11"
            Foreground="{ThemeResource TextMutedBrush}"
            Text="0 chars"
            Visibility="Collapsed" />

        <Grid x:Name="ActionGrid" Grid.Column="5" Margin="12,0,0,0">
            <Button
                x:Name="SendBtn"
                Click="Send_Click"
                Background="{ThemeResource AccentStrongBrush}"
                Foreground="{ThemeResource AccentTextBrush}"
                CornerRadius="8"
                MinWidth="54"
                MinHeight="46"
                Padding="14,8"
                TabIndex="15"
                ToolTipService.ToolTip="Send (Enter)"
                AutomationProperties.Name="Send message">
                <SymbolIcon Symbol="Send" />
            </Button>
            <ProgressRing
                x:Name="SendingRing"
                Width="24"
                Height="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Visibility="Collapsed" />
            <Button
                x:Name="StopBtn"
                Click="Stop_Click"
                Visibility="Collapsed"
                Background="{ThemeResource SurfaceElevatedBrush}"
                Foreground="{ThemeResource DangerBrush}"
                BorderBrush="{ThemeResource BorderSubtleBrush}"
                CornerRadius="8"
                MinWidth="54"
                MinHeight="46"
                Padding="14,8"
                ToolTipService.ToolTip="Stop"
                TabIndex="15"
                AutomationProperties.Name="Stop generation">
                <SymbolIcon Symbol="Stop" />
            </Button>
        </Grid>

        <!-- M4.9.5 Phase E2: slash command completion popup.
             WinUI Popup positions via offsets; we anchor it at the input box's
             top-left and lift it above the input. Filtered live as the user
             types a /-prefixed token; Tab/Enter/Up/Down/Esc in code-behind. -->
        <Popup
            x:Name="SlashPopup"
            Grid.Column="4"
            IsLightDismissEnabled="True"
            ShouldConstrainToRootBounds="False"
            VerticalOffset="-290"
            HorizontalOffset="0">
            <Border
                CornerRadius="8"
                BorderThickness="1"
                BorderBrush="{ThemeResource BorderSubtleBrush}"
                Background="{ThemeResource SurfaceElevatedBrush}"
                Padding="0"
                MinWidth="360"
                MaxWidth="560">
                <ListView
                    x:Name="SlashList"
                    MaxHeight="280"
                    IsItemClickEnabled="True"
                    AutomationProperties.Name="Slash command completion"
                    SelectionMode="Single"
                    CanReorderItems="False"
                    Padding="0"
                    ItemClick="SlashList_ItemClick">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="12,7,12,7" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border
                                    Grid.Column="0"
                                    CornerRadius="3"
                                    Padding="5,1,5,1"
                                    VerticalAlignment="Center"
                                    Background="{ThemeResource AccentSoftBrush}">
                                    <TextBlock
                                        Text="{Binding SourceLabel}"
                                        FontSize="10"
                                        Foreground="{ThemeResource AccentBrush}" />
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="1">
                                    <TextBlock FontFamily="{ThemeResource MonoFontFamily}" FontSize="13">
                                        <Run Text="/" /><Run Text="{Binding Name}" FontWeight="SemiBold" />
                                        <Run Text="{Binding ArgumentHint}" Foreground="{ThemeResource TextMutedBrush}" />
                                    </TextBlock>
                                    <TextBlock
                                        Text="{Binding Description}"
                                        FontSize="11"
                                        Foreground="{ThemeResource TextSecondaryBrush}"
                                        TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>
        </Popup>
    </Grid>
</UserControl>
