<UserControl
    x:Class="TLAHStudio.App.Views.Controls.CodeBlockControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    HorizontalContentAlignment="Stretch">

    <Border
        CornerRadius="{ThemeResource RadiusCard}"
        BorderThickness="1"
        BorderBrush="{ThemeResource BorderSubtleBrush}"
        Background="{ThemeResource SurfaceBrush}"
        Padding="0">
        <StackPanel>
            <!-- Header: fold chevron + language tag + line count + copy -->
            <Grid Padding="10,5,10,5" Background="{ThemeResource SurfaceElevatedBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button
                    x:Name="FoldButton"
                    Grid.Column="0"
                    Click="FoldButton_Click"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="4,2,4,2"
                    ToolTipService.ToolTip="Collapse / expand">
                    <FontIcon x:Name="FoldIcon" Glyph="&#xE70D;" FontFamily="Segoe Fluent Icons" />
                </Button>
                <Border
                    Grid.Column="1"
                    CornerRadius="{ThemeResource RadiusTag}"
                    Padding="6,2,6,2"
                    Background="{ThemeResource AccentSoftBrush}">
                    <TextBlock
                        x:Name="LanguageTag"
                        FontSize="10"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource AccentBrush}" />
                </Border>
                <TextBlock
                    x:Name="LineCountTag"
                    Grid.Column="3"
                    FontSize="10"
                    Foreground="{ThemeResource TextMutedBrush}"
                    VerticalAlignment="Center" />
                <Button
                    x:Name="CopyButton"
                    Grid.Column="4"
                    Click="CopyButton_Click"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="6,2,6,2"
                    ToolTipService.ToolTip="Copy code">
                    <SymbolIcon Symbol="Copy" />
                </Button>
            </Grid>
            <!-- Code body: line-number gutter + highlighted code, horizontal scroll -->
            <ScrollViewer
                x:Name="CodeScroll"
                HorizontalScrollBarVisibility="Auto"
                VerticalScrollBarVisibility="Auto"
                HorizontalScrollMode="Enabled"
                VerticalScrollMode="Auto"
                Padding="10,8,10,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        x:Name="LineNumberGutter"
                        Grid.Column="0"
                        Margin="0,0,10,0"
                        FontFamily="{ThemeResource MonoFontFamily}"
                        FontSize="12.5"
                        LineHeight="18"
                        Foreground="{ThemeResource TextMutedBrush}"
                        TextAlignment="Right"
                        TextWrapping="NoWrap"
                        IsTextSelectionEnabled="False" />
                    <RichTextBlock
                        x:Name="CodeText"
                        Grid.Column="1"
                        FontFamily="{ThemeResource MonoFontFamily}"
                        FontSize="12.5"
                        LineHeight="18"
                        IsTextSelectionEnabled="True"
                        TextWrapping="NoWrap"
                        HorizontalAlignment="Left" />
                </Grid>
            </ScrollViewer>
        </StackPanel>
    </Border>
</UserControl>
