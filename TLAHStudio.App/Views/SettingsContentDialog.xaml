<ContentDialog
    x:Class="TLAHStudio.App.Views.SettingsContentDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Settings"
    PrimaryButtonText="Save"
    CloseButtonText="Cancel"
    PrimaryButtonClick="Save_Click"
    Background="{ThemeResource DialogSurfaceBrush}"
    Width="700"
    MaxHeight="760">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="14" Padding="8,4,8,8">
            <Border
                HorizontalAlignment="Left"
                Padding="3"
                Background="{ThemeResource PanelAltBrush}"
                BorderBrush="{ThemeResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Orientation="Horizontal" Spacing="3">
                    <Button
                        x:Name="GlobalTabButton"
                        Tag="global"
                        Click="Scope_Click"
                        Content="All Chats"
                        Background="Transparent"
                        BorderThickness="0"
                        CornerRadius="6"
                        Padding="16,8" />
                    <Button
                        x:Name="ChatTabButton"
                        Tag="chat"
                        Click="Scope_Click"
                        Content="This Chat"
                        Background="Transparent"
                        BorderThickness="0"
                        CornerRadius="6"
                        Padding="16,8" />
                </StackPanel>
            </Border>

            <Border
                Padding="12,10"
                Background="{ThemeResource AccentSoftBrush}"
                BorderBrush="{ThemeResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <TextBlock
                x:Name="ScopeHint"
                Foreground="{ThemeResource TextSecondaryBrush}"
                TextWrapping="Wrap" />
            </Border>

            <Border
                x:Name="GlobalForm"
                Padding="14"
                Background="{ThemeResource SurfaceBrush}"
                BorderBrush="{ThemeResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="10">
                    <TextBlock Text="Connection defaults" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}" />
                    <TextBlock Text="Used by every chat unless a chat-level override is set." Foreground="{ThemeResource TextSecondaryBrush}" TextWrapping="Wrap" />
                    <Border
                        Padding="12"
                        Background="{ThemeResource PanelAltBrush}"
                        BorderBrush="{ThemeResource BorderSubtleBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <Grid RowSpacing="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Soundscape" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}" />
                                    <TextBlock Text="Short, generated interaction sounds for send, complete, navigation, and safety prompts." Foreground="{ThemeResource TextSecondaryBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                                <ToggleSwitch
                                    x:Name="SoundEffectsToggle"
                                    Grid.Column="1"
                                    OnContent="On"
                                    OffContent="Off"
                                    AutomationProperties.Name="Sound effects" />
                            </Grid>
                            <Grid Grid.Row="1" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Text="Volume"
                                    VerticalAlignment="Center"
                                    Foreground="{ThemeResource TextSecondaryBrush}" />
                                <Slider
                                    x:Name="SoundVolumeSlider"
                                    Grid.Column="1"
                                    Minimum="0"
                                    Maximum="1"
                                    StepFrequency="0.05"
                                    AutomationProperties.Name="Sound volume" />
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- M4.7.0: UI Appearance card -->
                    <Border
                        Padding="12"
                        Background="{ThemeResource PanelAltBrush}"
                        BorderBrush="{ThemeResource BorderSubtleBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <Grid RowSpacing="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid Row="0" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="160" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Theme" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}" />
                                    <TextBlock Text="Light or dark application appearance." Foreground="{ThemeResource TextSecondaryBrush}" TextWrapping="Wrap" FontSize="12" />
                                </StackPanel>
                                <ComboBox
                                    x:Name="ThemeCombo"
                                    Grid.Column="1"
                                    SelectionChanged="ThemeCombo_SelectionChanged"
                                    AutomationProperties.Name="Theme selector" />
                            </Grid>
                            <Grid Row="1" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="160" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Density" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}" />
                                    <TextBlock Text="Comfortable provides more spacing; Compact fits more content." Foreground="{ThemeResource TextSecondaryBrush}" TextWrapping="Wrap" FontSize="12" />
                                </StackPanel>
                                <ComboBox
                                    x:Name="DensityCombo"
                                    Grid.Column="1"
                                    SelectionChanged="DensityCombo_SelectionChanged"
                                    AutomationProperties.Name="Density selector" />
                            </Grid>
                            <!-- M4.9.0: Output style selector -->
                            <Grid Row="2" ColumnSpacing="12" Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="160" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Output Style" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}" />
                                    <TextBlock Text="Changes how the assistant explains and interacts." Foreground="{ThemeResource TextSecondaryBrush}" TextWrapping="Wrap" FontSize="12" />
                                </StackPanel>
                                <ComboBox
                                    x:Name="OutputStyleCombo"
                                    Grid.Column="1"
                                    SelectionChanged="OutputStyleCombo_SelectionChanged"
                                    AutomationProperties.Name="Output style selector" />
                            </Grid>
                        </Grid>
                    </Border>

                <!-- M4.9.0: Skills management -->
                <Border Padding="16,14" Margin="0,12,0,0"
                        Background="{ThemeResource SurfaceElevatedBrush}"
                        BorderBrush="{ThemeResource BorderSubtleBrush}"
                        BorderThickness="1" CornerRadius="8">
                    <StackPanel Spacing="10">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Skills" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}" />
                            <TextBlock x:Name="SkillsSummaryText" Text="Loading..." FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                        <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="SkillsListControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Spacing="1">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}" />
                                                <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{ThemeResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                            <Border Grid.Column="1" Padding="6,2" CornerRadius="4" Margin="8,0,0,0"
                                                    Background="{ThemeResource BorderSubtleBrush}">
                                                <TextBlock Text="{Binding Source}" FontSize="10" Foreground="{ThemeResource TextSecondaryBrush}" />
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button x:Name="OpenBundledSkillsButton" Click="OpenBundledSkills_Click"
                                        Background="{ThemeResource SurfaceElevatedBrush}"
                                        BorderBrush="{ThemeResource BorderSubtleBrush}"
                                        CornerRadius="6" Padding="10,6">
                                    <TextBlock Text="Open Bundled (built-in)" FontSize="12" />
                                </Button>
                                <Button x:Name="OpenUserSkillsButton" Click="OpenUserSkills_Click"
                                        Background="{ThemeResource SurfaceElevatedBrush}"
                                        BorderBrush="{ThemeResource BorderSubtleBrush}"
                                        CornerRadius="6" Padding="10,6">
                                    <TextBlock Text="Open User" FontSize="12" />
                                </Button>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button x:Name="OpenProjectSkillsButton" Click="OpenProjectSkills_Click"
                                        Background="{ThemeResource SurfaceElevatedBrush}"
                                        BorderBrush="{ThemeResource BorderSubtleBrush}"
                                        CornerRadius="6" Padding="10,6">
                                    <TextBlock Text="Open Project (.tlah/skills)" FontSize="12" />
                                </Button>
                                <Button x:Name="ReloadSkillsButton" Click="ReloadSkills_Click"
                                        Background="{ThemeResource SurfaceElevatedBrush}"
                                        BorderBrush="{ThemeResource BorderSubtleBrush}"
                                        CornerRadius="6" Padding="10,6">
                                    <TextBlock Text="Reload" FontSize="12" />
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <TextBlock Text="Provider" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                <ComboBox
                    x:Name="ProviderCombo"
                    Background="{ThemeResource InputBackgroundBrush}"
                    Foreground="{ThemeResource TextPrimaryBrush}"
                    BorderBrush="{ThemeResource BorderSubtleBrush}"
                    CornerRadius="8"
                    DisplayMemberPath="Name" />

                <TextBlock Text="API Key" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <PasswordBox
                        x:Name="ApiKeyBox"
                        PasswordRevealMode="Peek"
                        Grid.Column="0"
                        PlaceholderText="sk-..."
                        Background="{ThemeResource InputBackgroundBrush}"
                        Foreground="{ThemeResource TextPrimaryBrush}"
                        BorderBrush="{ThemeResource BorderSubtleBrush}"
                        CornerRadius="8" />
                    <Button
                        Grid.Column="1"
                        Click="TestGlobal_Click"
                        Padding="10,7"
                        CornerRadius="8"
                        ToolTipService.ToolTip="Test connection">
                        <SymbolIcon Symbol="Sync" />
                    </Button>
                    <Button
                        Grid.Column="2"
                        Click="ClearGlobalKey_Click"
                        Padding="10,7"
                        CornerRadius="8"
                        ToolTipService.ToolTip="Clear saved API key">
                        <SymbolIcon Symbol="Cancel" />
                    </Button>
                </Grid>

                <TextBlock Text="Base URL" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                <TextBox
                    x:Name="BaseUrlBox"
                    Background="{ThemeResource InputBackgroundBrush}"
                    Foreground="{ThemeResource TextPrimaryBrush}"
                    BorderBrush="{ThemeResource BorderSubtleBrush}"
                    CornerRadius="8" />

                <TextBlock Text="Model" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        x:Name="ModelBox"
                        Grid.Column="0"
                        InputScope="Text"
                        Background="{ThemeResource InputBackgroundBrush}"
                        Foreground="{ThemeResource TextPrimaryBrush}"
                        BorderBrush="{ThemeResource BorderSubtleBrush}"
                        CornerRadius="8" />
                    <ComboBox
                        x:Name="ModelPicker"
                        Grid.Column="1"
                        PlaceholderText="Detected models"
                        SelectionChanged="ModelPicker_SelectionChanged"
                        Background="{ThemeResource InputBackgroundBrush}"
                        Foreground="{ThemeResource TextPrimaryBrush}"
                        BorderBrush="{ThemeResource BorderSubtleBrush}"
                        CornerRadius="8" />
                    <Button
                        Grid.Column="2"
                        Click="RefreshGlobalModels_Click"
                        Padding="10,7"
                        CornerRadius="8"
                        ToolTipService.ToolTip="Refresh model list">
                        <SymbolIcon Symbol="Sync" />
                    </Button>
                </Grid>
                <CheckBox
                    x:Name="DeepSeekLongContextCheckBox"
                    Content="Use DeepSeek 1M context budget"
                    Checked="DeepSeekLongContext_Changed"
                    Unchecked="DeepSeekLongContext_Changed"
                    Foreground="{ThemeResource TextSecondaryBrush}" />

                <TextBlock Text="Thinking Depth" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                <ComboBox
                    x:Name="ThinkingDepthCombo"
                    Background="{ThemeResource InputBackgroundBrush}"
                    Foreground="{ThemeResource TextPrimaryBrush}"
                    BorderBrush="{ThemeResource BorderSubtleBrush}"
                    CornerRadius="8" />

                <TextBlock Text="Temperature" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Slider
                        x:Name="TempSlider"
                        Grid.Column="0"
                        Minimum="0"
                        Maximum="2"
                        StepFrequency="0.1"
                        ValueChanged="TempSlider_ValueChanged" />
                    <!-- M4.7.0: Live temperature value label -->
                    <TextBlock
                        x:Name="TempValueLabel"
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        MinWidth="32"
                        TextAlignment="Right"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextPrimaryBrush}"
                        Text="0.7" />
                </Grid>

                <TextBlock Text="Max Tokens" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                <NumberBox
                    x:Name="MaxTokensBox"
                    Minimum="1"
                    Maximum="128000" />

                <TextBlock Text="System Prompt" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                <TextBox
                    x:Name="SysPromptBox"
                    AcceptsReturn="True"
                    InputScope="Text"
                    MinHeight="96"
                    Background="{ThemeResource InputBackgroundBrush}"
                    Foreground="{ThemeResource TextPrimaryBrush}"
                    BorderBrush="{ThemeResource BorderSubtleBrush}"
                    CornerRadius="8" />

                <TextBlock Text="User Role" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                <TextBox
                    x:Name="UserRoleBox"
                    InputScope="Text"
                    Background="{ThemeResource InputBackgroundBrush}"
                    Foreground="{ThemeResource TextPrimaryBrush}"
                    BorderBrush="{ThemeResource BorderSubtleBrush}"
                    CornerRadius="8" />
                </StackPanel>
            </Border>

            <!-- M4.7.0: Reset global settings to defaults -->
            <HyperlinkButton
                Content="Reset to defaults"
                HorizontalAlignment="Right"
                FontSize="12"
                Click="ResetGlobal_Click"
                AutomationProperties.Name="Reset settings to defaults" />

            <Border
                x:Name="ChatForm"
                Padding="14"
                Background="{ThemeResource SurfaceBrush}"
                BorderBrush="{ThemeResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Visibility="Collapsed">
                <StackPanel Spacing="10">
                    <TextBlock Text="Chat overrides" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}" />
                    <TextBlock Text="Leave a value empty to inherit the corresponding global setting." Foreground="{ThemeResource TextSecondaryBrush}" TextWrapping="Wrap" />
                <TextBlock Text="Provider Override" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox
                        x:Name="ChatProviderCombo"
                        Grid.Column="0"
                        Background="{ThemeResource InputBackgroundBrush}"
                        Foreground="{ThemeResource TextPrimaryBrush}"
                        BorderBrush="{ThemeResource BorderSubtleBrush}"
                        CornerRadius="8"
                        DisplayMemberPath="Name"
                        PlaceholderText="Use global provider" />
                    <Button
                        Grid.Column="1"
                        Click="ClearChatProvider_Click"
                        Background="Transparent"
                        Foreground="{ThemeResource TextMutedBrush}"
                        BorderThickness="0"
                        Padding="8,6"
                        ToolTipService.ToolTip="Use global provider">
                        <SymbolIcon Symbol="Cancel" />
                    </Button>
                </Grid>

                <TextBlock Text="API Key Override" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <PasswordBox
                        x:Name="ChatApiKeyBox"
                        PasswordRevealMode="Peek"
                        Grid.Column="0"
                        PlaceholderText="Leave blank to inherit"
                        Background="{ThemeResource InputBackgroundBrush}"
                        Foreground="{ThemeResource TextPrimaryBrush}"
                        BorderBrush="{ThemeResource BorderSubtleBrush}"
                        CornerRadius="8" />
                    <Button
                        Grid.Column="1"
                        Click="TestChat_Click"
                        Padding="10,7"
                        CornerRadius="8"
                        ToolTipService.ToolTip="Test chat connection">
                        <SymbolIcon Symbol="Sync" />
                    </Button>
                    <Button
                        Grid.Column="2"
                        Click="ClearChatKey_Click"
                        Padding="10,7"
                        CornerRadius="8"
                        ToolTipService.ToolTip="Clear chat API key override">
                        <SymbolIcon Symbol="Cancel" />
                    </Button>
                </Grid>

                <TextBlock Text="Base URL Override" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                <TextBox
                    x:Name="ChatBaseUrlBox"
                    PlaceholderText="Leave blank to inherit"
                    Background="{ThemeResource InputBackgroundBrush}"
                    Foreground="{ThemeResource TextPrimaryBrush}"
                    BorderBrush="{ThemeResource BorderSubtleBrush}"
                    CornerRadius="8" />

                <TextBlock Text="Model Override" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        x:Name="ChatModelBox"
                        Grid.Column="0"
                        PlaceholderText="Leave blank to inherit"
                        Background="{ThemeResource InputBackgroundBrush}"
                        Foreground="{ThemeResource TextPrimaryBrush}"
                        BorderBrush="{ThemeResource BorderSubtleBrush}"
                        CornerRadius="8" />
                    <ComboBox
                        x:Name="ChatModelPicker"
                        Grid.Column="1"
                        PlaceholderText="Detected models"
                        SelectionChanged="ChatModelPicker_SelectionChanged"
                        Background="{ThemeResource InputBackgroundBrush}"
                        Foreground="{ThemeResource TextPrimaryBrush}"
                        BorderBrush="{ThemeResource BorderSubtleBrush}"
                        CornerRadius="8" />
                    <Button
                        Grid.Column="2"
                        Click="RefreshChatModels_Click"
                        Padding="10,7"
                        CornerRadius="8"
                        ToolTipService.ToolTip="Refresh chat model list">
                        <SymbolIcon Symbol="Sync" />
                    </Button>
                </Grid>
                <CheckBox
                    x:Name="ChatDeepSeekLongContextCheckBox"
                    Content="Use DeepSeek 1M context budget"
                    Checked="ChatDeepSeekLongContext_Changed"
                    Unchecked="ChatDeepSeekLongContext_Changed"
                    Foreground="{ThemeResource TextSecondaryBrush}" />

                <TextBlock Text="Thinking Depth Override" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                <ComboBox
                    x:Name="ChatThinkingDepthCombo"
                    Background="{ThemeResource InputBackgroundBrush}"
                    Foreground="{ThemeResource TextPrimaryBrush}"
                    BorderBrush="{ThemeResource BorderSubtleBrush}"
                    CornerRadius="8" />

                <TextBlock Text="Temperature Override" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                <TextBox
                    x:Name="ChatTempBox"
                    PlaceholderText="Leave blank to inherit"
                    Background="{ThemeResource InputBackgroundBrush}"
                    Foreground="{ThemeResource TextPrimaryBrush}"
                    BorderBrush="{ThemeResource BorderSubtleBrush}"
                    CornerRadius="8" />

                <TextBlock Text="Max Tokens Override" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                <TextBox
                    x:Name="ChatMaxTokensBox"
                    PlaceholderText="Leave blank to inherit"
                    Background="{ThemeResource InputBackgroundBrush}"
                    Foreground="{ThemeResource TextPrimaryBrush}"
                    BorderBrush="{ThemeResource BorderSubtleBrush}"
                    CornerRadius="8" />

                <TextBlock Text="User Role Override" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                <TextBox
                    x:Name="ChatUserRoleBox"
                    PlaceholderText="Leave blank to inherit"
                    Background="{ThemeResource InputBackgroundBrush}"
                    Foreground="{ThemeResource TextPrimaryBrush}"
                    BorderBrush="{ThemeResource BorderSubtleBrush}"
                    CornerRadius="8" />
                </StackPanel>
            </Border>

            <TextBlock
                x:Name="TestText"
                Foreground="{ThemeResource TextSecondaryBrush}"
                TextWrapping="Wrap"
                Visibility="Collapsed" />

            <TextBlock
                x:Name="ErrorText"
                Foreground="{ThemeResource DangerBrush}"
                TextWrapping="Wrap"
                Visibility="Collapsed" />
        </StackPanel>
    </ScrollViewer>
</ContentDialog>
