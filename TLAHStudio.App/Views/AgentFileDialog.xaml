<ContentDialog
    x:Class="TLAHStudio.App.Views.AgentFileDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="AGENT.md"
    CloseButtonText="Done"
    Background="{ThemeResource DialogSurfaceBrush}"
    Width="640"
    MaxHeight="720">

    <Grid>
        <Border
            x:Name="NoChatPanel"
            Padding="16"
            Background="{ThemeResource AccentSoftBrush}"
            BorderBrush="{ThemeResource BorderSubtleBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <StackPanel Spacing="6">
                <TextBlock
                    Text="Select a chat before attaching AGENT.md."
                    Foreground="{ThemeResource TextPrimaryBrush}"
                    FontSize="14"
                    FontWeight="SemiBold" />
                <TextBlock
                    Text="The file is stored per chat and appended to that chat's system prompt."
                    Foreground="{ThemeResource TextSecondaryBrush}"
                    TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <StackPanel x:Name="AgentPanel" Spacing="14" Visibility="Collapsed">
            <Border
                Padding="8"
                Background="{ThemeResource PanelAltBrush}"
                BorderBrush="{ThemeResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button
                        Click="Upload_Click"
                        Background="{ThemeResource AccentBrush}"
                        Foreground="{ThemeResource AccentTextBrush}"
                        BorderThickness="0"
                        CornerRadius="8"
                        Padding="12,8">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <SymbolIcon Symbol="Upload" />
                            <TextBlock Text="Upload" />
                        </StackPanel>
                    </Button>
                    <Button
                        x:Name="DeleteButton"
                        Click="Delete_Click"
                        Background="Transparent"
                        Foreground="{ThemeResource DangerBrush}"
                        BorderThickness="0"
                        CornerRadius="8"
                        Padding="12,8">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <SymbolIcon Symbol="Delete" />
                            <TextBlock Text="Remove" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <TextBlock
                x:Name="StatusText"
                Foreground="{ThemeResource TextSecondaryBrush}"
                TextWrapping="Wrap" />

            <Border
                Background="{ThemeResource SurfaceBrush}"
                BorderBrush="{ThemeResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Height="380"
                MaxHeight="380">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock
                        Text="Preview"
                        Padding="14,10"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource TextSecondaryBrush}" />
                    <ScrollViewer
                        Grid.Row="1"
                        Padding="14,10,14,14"
                        BorderBrush="{ThemeResource BorderSubtleBrush}"
                        BorderThickness="0,1,0,0"
                        VerticalScrollBarVisibility="Auto"
                        VerticalScrollMode="Enabled"
                        HorizontalScrollBarVisibility="Disabled">
                        <TextBlock
                            x:Name="PreviewText"
                            Foreground="{ThemeResource TextPrimaryBrush}"
                            FontFamily="Consolas"
                            FontSize="12"
                            LineHeight="19"
                            TextWrapping="Wrap" />
                    </ScrollViewer>
                </Grid>
            </Border>
        </StackPanel>
    </Grid>
</ContentDialog>
