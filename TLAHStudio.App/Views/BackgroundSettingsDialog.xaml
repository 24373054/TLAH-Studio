<ContentDialog
    x:Class="TLAHStudio.App.Views.BackgroundSettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Background"
    PrimaryButtonText="Apply"
    SecondaryButtonText="Reset"
    CloseButtonText="Close"
    PrimaryButtonClick="Save_Click"
    SecondaryButtonClick="Reset_Click"
    Background="{ThemeResource DialogSurfaceBrush}"
    Width="560">

    <StackPanel Spacing="16" Padding="4,2,4,4">
        <Border
            Height="210"
            Background="{ThemeResource SurfaceBrush}"
            BorderBrush="{ThemeResource BorderSubtleBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <Grid>
                <Image
                    x:Name="PreviewImage"
                    Stretch="UniformToFill"
                    Opacity="0" />
                <Rectangle
                    x:Name="PreviewBrightnessOverlay"
                    Fill="#000000"
                    Opacity="0" />
                <TextBlock
                    x:Name="NoImageText"
                    Text="No background selected"
                    Foreground="{ThemeResource TextSecondaryBrush}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center" />
                <Button
                    Click="Pick_Click"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="12"
                    Background="{ThemeResource SurfaceElevatedBrush}"
                    Foreground="{ThemeResource TextPrimaryBrush}"
                    BorderBrush="{ThemeResource BorderStrongBrush}"
                    CornerRadius="8"
                    Padding="12,8">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <SymbolIcon Symbol="Pictures" />
                        <TextBlock Text="Choose Image" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Border
            Padding="16,14"
            Background="{ThemeResource SurfaceBrush}"
            BorderBrush="{ThemeResource BorderSubtleBrush}"
            BorderThickness="1"
            CornerRadius="8">
            <StackPanel Spacing="14">
                <TextBlock Text="Appearance" FontSize="16" FontWeight="SemiBold" Foreground="{ThemeResource TextPrimaryBrush}" />
                <StackPanel Spacing="5">
                    <TextBlock x:Name="BrightnessValue" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                    <Slider
                        x:Name="BrightnessSlider"
                        Minimum="0"
                        Maximum="200"
                        StepFrequency="1"
                        ValueChanged="Preview_ValueChanged" />
                </StackPanel>

                <StackPanel Spacing="5">
                    <TextBlock x:Name="OpacityValue" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                    <Slider
                        x:Name="OpacitySlider"
                        Minimum="0"
                        Maximum="100"
                        StepFrequency="1"
                        ValueChanged="Preview_ValueChanged" />
                </StackPanel>

                <StackPanel Spacing="5">
                    <TextBlock x:Name="ChatOpacityValue" FontSize="12" Foreground="{ThemeResource TextSecondaryBrush}" />
                    <Slider
                        x:Name="ChatOpacitySlider"
                        Minimum="5"
                        Maximum="100"
                        StepFrequency="1"
                        ValueChanged="Preview_ValueChanged" />
                </StackPanel>
            </StackPanel>
        </Border>
    </StackPanel>
</ContentDialog>
