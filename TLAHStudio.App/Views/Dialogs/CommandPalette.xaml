<ContentDialog
    x:Class="TLAHStudio.App.Views.Dialogs.CommandPalette"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Command Palette"
    PrimaryButtonText="Execute"
    CloseButtonText="Close"
    DefaultButton="Primary">
    <Grid RowSpacing="8" MinWidth="460" MaxWidth="620">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBox
            x:Name="SearchBox"
            Grid.Row="0"
            TextChanged="SearchBox_TextChanged"
            PlaceholderText="Type to search commands…"
            AutomationProperties.Name="Command search" />
        <ListView
            x:Name="CommandList"
            Grid.Row="1"
            MaxHeight="360"
            IsItemClickEnabled="True"
            ItemClick="CommandList_ItemClick"
            Padding="0">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="10,6" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" CornerRadius="3" Padding="4,1" Background="{ThemeResource AccentSoftBrush}" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Category}" FontSize="10" Foreground="{ThemeResource AccentBrush}" />
                        </Border>
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{ThemeResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</ContentDialog>
