<Window
    x:Class="TLAHStudio.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:TLAHStudio.App.Views"
    Title="TLAH Studio">

    <Grid
        x:Name="RootGrid"
        Background="{ThemeResource AppBackgroundBrush}"
        AutomationProperties.Name="TLAH Studio workspace">
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="TitleBarDragRegion"
            Grid.Row="0"
            Background="{ThemeResource AppChromeBrush}"
            BorderBrush="{ThemeResource BorderSubtleBrush}"
            BorderThickness="0,0,0,1"
            MinHeight="44">
            <Border
                Width="26"
                Height="26"
                Margin="14,0,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Background="{ThemeResource BrandMarkBrush}"
                BorderBrush="{ThemeResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Image
                    Source="ms-appx:///Assets/logo.png"
                    Width="18"
                    Height="18"
                    Stretch="Uniform"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center" />
            </Border>
            <TextBlock
                Text="TLAH Studio"
                Margin="50,0,160,0"
                VerticalAlignment="Center"
                Foreground="{ThemeResource TextSecondaryBrush}"
                FontSize="13"
                FontWeight="SemiBold" />
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <views:SidebarPage x:Name="SidebarView" Grid.Column="0" />

            <Grid Grid.Column="1">
                <Image
                    x:Name="BackgroundImage"
                    Stretch="UniformToFill"
                    Opacity="0"
                    IsHitTestVisible="False" />
                <Rectangle
                    x:Name="BrightnessOverlay"
                    Fill="#000000"
                    Opacity="0"
                    IsHitTestVisible="False" />

                <Grid
                    x:Name="WorkbenchGrid"
                    Background="{ThemeResource WorkbenchOverlayBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition x:Name="AgentActivityColumn" Width="0" MinWidth="0" />
                    </Grid.ColumnDefinitions>
                    <views:ChatHeaderControl x:Name="ChatHeaderView" Grid.Row="0" Grid.Column="0" />
                    <views:ChatPage x:Name="ChatPageView" Grid.Row="1" Grid.Column="0" />
                    <views:MessageInputControl x:Name="MessageInputView" Grid.Row="2" Grid.Column="0" />
                    <views:AgentActivityPanelControl
                        x:Name="AgentActivityPanelView"
                        Grid.Row="0"
                        Grid.RowSpan="3"
                        Grid.Column="1"
                        Visibility="Collapsed" />
                </Grid>
            </Grid>

            <views:DebugPanelControl
                x:Name="DebugPanelView"
                Grid.ColumnSpan="2"
                HorizontalAlignment="Right"
                VerticalAlignment="Stretch" />
        </Grid>
    </Grid>
</Window>
