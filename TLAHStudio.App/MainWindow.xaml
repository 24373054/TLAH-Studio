<Window
    x:Class="TLAHStudio.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:TLAHStudio.App.Views"
    Title="TLAH Studio">

    <Grid
        x:Name="RootGrid"
        Background="{ThemeResource AppBackgroundBrush}"
        AutomationProperties.Name="TLAH Studio workspace">
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="TitleBarDragRegion"
            Grid.Row="0"
            Background="{ThemeResource AppChromeBrush}"
            BorderBrush="{ThemeResource BorderSubtleBrush}"
            BorderThickness="0,0,0,1"
            MinHeight="48">
            <Border
                Width="28"
                Height="28"
                Margin="14,0,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Background="{ThemeResource BrandMarkBrush}"
                BorderBrush="{ThemeResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="9">
                <Image
                    Source="ms-appx:///Assets/logo.png"
                    Width="19"
                    Height="19"
                    Stretch="Uniform"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center" />
            </Border>
            <StackPanel Margin="54,0,160,0" VerticalAlignment="Center" Spacing="0">
                <TextBlock
                    Text="TLAH Studio"
                    Foreground="{ThemeResource TextPrimaryBrush}"
                    FontSize="13"
                    FontWeight="SemiBold" />
                <TextBlock
                    Text="AGENT WORKSPACE"
                    Foreground="{ThemeResource TextMutedBrush}"
                    FontSize="9"
                    FontWeight="SemiBold"
                    CharacterSpacing="70" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <views:SidebarPage x:Name="SidebarView" Grid.Column="0" />

            <Grid Grid.Column="1">
                <Rectangle
                    Fill="{ThemeResource NocturneAmbientBrush}"
                    Opacity="0.44"
                    IsHitTestVisible="False" />
                <Image
                    x:Name="BackgroundImage"
                    Stretch="UniformToFill"
                    Opacity="0"
                    IsHitTestVisible="False" />
                <Rectangle
                    x:Name="BrightnessOverlay"
                    Fill="#000000"
                    Opacity="0"
                    IsHitTestVisible="False" />

                <Grid
                    x:Name="WorkbenchGrid"
                    Background="{ThemeResource WorkbenchOverlayBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition x:Name="AgentActivityColumn" Width="0" MinWidth="0" />
                        <ColumnDefinition x:Name="WorkspaceReviewColumn" Width="0" MinWidth="0" />
                    </Grid.ColumnDefinitions>
                    <views:ChatHeaderControl x:Name="ChatHeaderView" Grid.Row="0" Grid.Column="0" />
                    <views:ChatPage x:Name="ChatPageView" Grid.Row="1" Grid.Column="0" />
                    <views:MessageInputControl x:Name="MessageInputView" Grid.Row="2" Grid.Column="0" />
                    <views:AgentActivityPanelControl
                        x:Name="AgentActivityPanelView"
                        Grid.Row="0"
                        Grid.RowSpan="3"
                        Grid.Column="1"
                        Visibility="Collapsed" />
                    <views:WorkspaceReviewPanelControl
                        x:Name="WorkspaceReviewPanelView"
                        Grid.Row="0"
                        Grid.RowSpan="3"
                        Grid.Column="2"
                        Visibility="Collapsed" />
                </Grid>
            </Grid>

            <views:DebugPanelControl
                x:Name="DebugPanelView"
                Grid.ColumnSpan="2"
                HorizontalAlignment="Right"
                VerticalAlignment="Stretch" />
        </Grid>
    </Grid>
</Window>
